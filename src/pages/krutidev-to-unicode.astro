---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { CONVERTERS } from '../config/converters';

const converterInfo = CONVERTERS.find(c => c.id === 'krutidev-to-unicode');
if (!converterInfo) {
  throw new Error("Converter configuration for ID 'krutidev-to-unicode' not found in registry.");
}

const faqs = converterInfo.faq;

// Generate JSON-LD schemas
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "KrutiDev to Unicode Converter – Free Online Tool (KrutiDev 010 / Kurtidev10)",
  "description": "Convert KrutiDev 010 (kurtidev10) Hindi text to Unicode (Mangal) online, free and instantly. Paste your KrutiDev or Kurtidev10 text and get clean Unicode output for Word, web, WhatsApp, and Marathi documents.",
  "url": new URL('/krutidev-to-unicode/', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "KrutiDev to Unicode Converter",
  "description": "Convert KrutiDev 010 Hindi text to Unicode (Mangal) online, free and instantly. Paste your KrutiDev text and get clean Unicode output.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "browserRequirements": "Requires JavaScript.",
  "url": new URL('/krutidev-to-unicode/', Astro.site || 'https://fontconverterhub.com').href
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fontconverterhub.com/" },
    { "@type": "ListItem", "position": 2, "name": "KrutiDev to Unicode Converter", "item": "https://fontconverterhub.com/krutidev-to-unicode/" }
  ]
};

const schemas = [pageSchema, appSchema, faqSchema, breadcrumbSchema];
---

<Layout
  title="KrutiDev to Unicode Converter – Free Online Tool (KrutiDev 010 / Kurtidev10)"
  description="Convert KrutiDev 010 (kurtidev10) Hindi text to Unicode (Mangal) online, free and instantly. Paste your KrutiDev or Kurtidev10 text and get clean Unicode output for Word, web, WhatsApp, and Marathi documents."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first, above fold) -->
      <Converter
        direction="krutidev-to-unicode"
        inputPlaceholder={converterInfo.placeholders.input}
        outputPlaceholder={converterInfo.placeholders.output}
        swapTarget="/unicode-to-krutidev"
        examples={converterInfo.examples}
        inputLabel="KrutiDev Text"
        outputLabel="Unicode Text (Mangal)"
      />

      <!-- Compact Utility Title and Disambiguation Notice -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          KrutiDev to Unicode Converter — Free Online Tool (KrutiDev 010 / Kurtidev10)
        </h1>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1.5 leading-none">
          Paste your KrutiDev (or KrutiDev 010) Hindi text below and convert it to Unicode in one click — free, instant, and no login required. Works for Hindi and Marathi documents, government files, old DTP content, and anywhere you need text to display correctly on modern devices without installing a special font.
        </p>
        
        <!-- Disambiguation Links -->
        <div class="flex gap-2.5 flex-wrap mt-5 select-text">
          <a
            href="/unicode-to-krutidev/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Reverse: Unicode to KrutiDev
          </a>
          <a
            href="/krutidev-to-chanakya-converter/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Need Chanakya font? KrutiDev to Chanakya
          </a>
          <a
            href="/krutidev-to-mangal-converter/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Need Mangal? KrutiDev to Mangal
          </a>
        </div>
      </div>

      <!-- How To Use (How to use second) -->
      <HowToUse
        title={converterInfo.howTo.title}
        steps={converterInfo.howTo.steps}
        type={converterInfo.howTo.type}
      />

      <!-- Custom Content Sections (About Section layout) -->
      <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
        <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
          <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Detailed Guide: KrutiDev to Unicode Conversion
        </h2>
        <div class="text-sm text-slate-650 dark:text-slate-350 space-y-6 leading-relaxed font-normal">
          
          <!-- Section 1: What Is KrutiDev to Unicode Conversion? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Is KrutiDev to Unicode Conversion?</h3>
            <p>
              KrutiDev (also written Kruti Dev or KrutiDev 010) is a legacy non-Unicode Hindi font that has been used across Indian government offices, courts, typing institutes, and old DTP/print software since the 1990s. It maps Hindi glyphs onto English ASCII keys in a non-standard way, which means KrutiDev text only displays correctly if the exact same font is installed — on a phone, website, or any modern app without that font, it shows up as garbled symbols.
            </p>
            <p>
              Unicode is the universal standard used by every modern device, browser, and operating system. Converting KrutiDev to Unicode takes that old ASCII-mapped text and rebuilds it as proper Devanagari Unicode — readable anywhere, searchable, copy-paste friendly, and compatible with Mangal, Nirmala UI, or any other Unicode Hindi font.
            </p>
            <p class="mt-2.5">
              If you need the KrutiDev font installed on your system to read legacy documents before converting, you can <a href="/krutidev-font-download" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">download KrutiDev font for free</a> from our resource page. For help with key mappings, see our <a href="/krutidev-keyboard-layout" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">KrutiDev keyboard layout chart</a>.
            </p>
            <p class="mt-2.5">
              This tool also correctly repositions characters like ikar (ि) and reph (र्), which sit in a different order in KrutiDev than they do in Unicode — a common source of broken conversions in cheaper tools.
            </p>
            <p class="mt-2.5 text-xs italic text-slate-500 dark:text-slate-400">
              Note: If your KrutiDev text currently displays as symbols like dsfjsd Á%hkjk█ in a plain text editor, that's expected — it just means the KrutiDev 010 font isn't applied. Paste it into the tool above as-is; you don't need to "fix" it first.
            </p>
          </div>

          <!-- Section 2: How to Convert KrutiDev to Unicode Online -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">How to Convert KrutiDev to Unicode Online</h3>
            <ol class="list-decimal pl-5 space-y-2 mt-2 text-sm">
              <li>Paste your KrutiDev (KrutiDev 010) text into the input box above — copy it directly from Word, PDF, or wherever it currently lives.</li>
              <li>Click Convert to Unicode.</li>
              <li>Copy the Unicode output — it will display correctly in any standard font like Mangal or Nirmala UI, no special font needed.</li>
              <li>Paste it into Word, WhatsApp, a website, or any Unicode-compatible app.</li>
            </ol>
            <p class="mt-3">
              For Excel files, paste each KrutiDev cell's content into the converter individually, or copy a column at a time — the tool handles multi-line text in a single pass.
            </p>
          </div>

          <!-- Section 3: KrutiDev to Unicode — Comparison Table -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">KrutiDev to Unicode — Comparison Table</h3>
            
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Term</th>
                    <th>What it means</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">KrutiDev to Unicode</td>
                    <td>Convert legacy KrutiDev font text &rarr; universal Unicode (Mangal-compatible)</td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev 010 to Unicode</td>
                    <td>Same thing — "010" is the specific, most common KrutiDev version</td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev to Mangal</td>
                    <td>Same result — Mangal is the most widely used Unicode Hindi font, so converting "to Unicode" and "to Mangal" produce the same text</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Unicode to KrutiDev</td>
                    <td>The reverse — see our <a href="/unicode-to-krutidev/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Unicode to KrutiDev Converter</a></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Section 4: Who Needs to Convert KrutiDev to Unicode? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Needs to Convert KrutiDev to Unicode?</h3>
            <ul class="list-disc pl-5 space-y-2 mt-2 text-sm">
              <li><strong>Government and court staff</strong> holding decades of old KrutiDev-formatted letters, judgments, and records who need to digitize them into a searchable, future-proof Unicode format.</li>
              <li><strong>Marathi and Hindi typists</strong> — KrutiDev was widely used for Marathi typing in Maharashtra government offices too, not just Hindi; this tool converts both correctly.</li>
              <li><strong>Students and typing exam candidates</strong> who learned on KrutiDev-based typing software but need Unicode output for online forms, applications, and modern documents.</li>
              <li><strong>Web publishers and bloggers</strong> with old KrutiDev-era Hindi content that displays as broken symbols on today's websites and needs to be restored to readable Unicode for SEO and accessibility.</li>
              <li><strong>Office and DTP professionals</strong> migrating old press/print files into modern Unicode-based publishing workflows.</li>
            </ul>
          </div>

          <!-- Section 5: KrutiDev 010 and KrutiDev 10 — Are They the Same? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">KrutiDev 010 and KrutiDev 10 — Are They the Same?</h3>
            <p>
              Yes. KrutiDev 010 and KrutiDev 10 refer to the same font — the most widely used variant in the KrutiDev family. Whether your document uses the font labelled "KrutiDev 010" or "KrutiDev 10", the character encoding is identical and this converter handles both correctly. Other variants in the family — KrutiDev 011, 016, 020, and others — use the same core Remington mapping and are also supported.
            </p>
            <p class="mt-2.5">
              Users often search for this tool as "kurtidev10 to unicode" 
              or "kurtidev 10 to unicode" — these are alternate spellings 
              of the same converter. Whether you type KrutiDev, Krutidev, 
              or Kurtidev, this free online tool converts all KrutiDev 010 
              encoded Hindi text to Unicode correctly.
            </p>
          </div>

          <!-- Section 6: Converting KrutiDev Files in Microsoft Word -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Converting KrutiDev Files in Microsoft Word</h3>
            <p>
              This is one of the most common use cases. If you have a Word document (.doc or .docx) typed in KrutiDev 010, open the file and the text will appear as garbled English characters if KrutiDev is not installed on your system. Select all the garbled text, copy it, and paste it into this KrutiDev to Unicode converter. Copy the Unicode output, paste it back into Word, and change the font to Mangal or Nirmala UI. The Hindi text will display and print correctly on any computer without needing KrutiDev installed.
            </p>
            <p class="mt-2.5">
              The same process works for KrutiDev text in Notepad, LibreOffice Writer, and other document editors.
            </p>
          </div>

          <!-- Section 7: KrutiDev Hindi and Marathi Font Users -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">KrutiDev Hindi and Marathi Font Users</h3>
            <p>
              KrutiDev is widely used for both Hindi and Marathi typing. The Devanagari script is shared between the two languages, so this KrutiDev to Unicode converter works equally well for Marathi documents — government records, newspapers, court documents, and DTP layouts typed in KrutiDev Marathi are all converted accurately to Unicode Devanagari output.
            </p>
          </div>

          <!-- Section 8: What Does KrutiDev 010 Text Look Like Without the Font? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Does KrutiDev 010 Text Look Like Without the Font?</h3>
            <p>
              Without the KrutiDev font installed, KrutiDev-encoded text appears as a string of English letters and symbols. For example, the word भारत appears as "Hkkjr", हिंदी appears as "fgUnh", and नमस्ते appears as "ueLrs". This is not corruption or an error — the text is intact and converts correctly. Copy the visible ASCII characters and paste them into this converter to recover the original Hindi text.
            </p>
          </div>

          <!-- Section 9: Who Uses This KrutiDev to Unicode Converter? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Uses This KrutiDev to Unicode Converter?</h3>
            <p>
              This tool is used daily by:
            </p>
            <p class="mt-1.5">
              — Government employees converting legacy court and office documents for e-filing portals
            </p>
            <p class="mt-1.5">
              — Typing exam candidates (SSC, UPSSSC, CPCT, MP Vyapam) who need to convert practice files to Unicode
            </p>
            <p class="mt-1.5">
              — Journalists and editors migrating KrutiDev archives to modern CMS platforms
            </p>
            <p class="mt-1.5">
              — Teachers and students who received old KrutiDev Hindi assignments and need readable Unicode output
            </p>
            <p class="mt-2.5">
              If your file shows garbled characters without the KrutiDev 010 font, this free online converter is the fastest fix.
            </p>
          </div>

        </div>
      </section>

      <!-- Related Tools -->
      <RelatedTools currentPath="/krutidev-to-unicode" />

      <!-- FAQ Section (Reusing FAQ component) -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>

<style>
  /* Custom heading spacing inside the detailed guide card */
  h3 {
    margin-top: 1.5rem;
  }
  
  /* Clean table styling matching keyboard layout page */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: rgba(248, 250, 252, 0.5);
  }
  
  .dark .font-table tr:hover {
    background-color: rgba(30, 41, 59, 0.3);
  }
</style>
