---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Contact' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Font Converter Hub",
  "description": "Get in touch with Font Converter Hub for support, feedback, bug reports, or font converter feature requests.",
  "url": new URL('/contact', Astro.site || 'https://fontconverterhub.com').href
};
---

<Layout
  title="Contact Support"
  description="Contact Font Converter Hub. Let us know about issues, suggest features, or ask questions about Devanagari font conversion."
  schema={schema}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbs} />

      <!-- Hero Section -->
      <div class="text-center mt-6 mb-12">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-brand-50 dark:bg-brand-950/40 text-brand-700 dark:text-brand-400 border border-brand-200/10 mb-4">
          Get in Touch
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight mb-4">
          We'd Love to Hear From You
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 leading-relaxed max-w-xl mx-auto">
          Have feedback, found a conversion bug, or need a specific font layout supported? Drop us an email and we will get back to you as soon as possible.
        </p>
      </div>

      <!-- Contact Card -->
      <div class="border border-slate-200/60 dark:border-slate-800/60 rounded-2xl bg-white dark:bg-slate-900 p-6 sm:p-10 shadow-xs mb-8">
        <div class="flex flex-col items-center text-center">
          
          <!-- Mail Icon -->
          <div class="w-12 h-12 rounded-xl bg-brand-50 dark:bg-brand-950/50 flex items-center justify-center text-brand-600 dark:text-brand-400 mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>

          <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2">
            Email Support & Feedback
          </h2>
          
          <!-- Interactive Email Display -->
          <div class="mt-4 p-3 px-6 rounded-xl bg-slate-50 dark:bg-slate-950/40 border border-slate-100 dark:border-slate-800/60 flex flex-col sm:flex-row items-center gap-3">
            <span id="email-address" class="font-mono text-sm sm:text-base font-semibold text-slate-800 dark:text-slate-200">
              support@fontconverterhub.com
            </span>
            <button 
              id="copy-email-btn"
              class="inline-flex items-center justify-center p-1.5 px-3 rounded-lg text-xs font-semibold bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-brand-500 hover:text-brand-600 dark:hover:text-brand-400 cursor-pointer shadow-2xs transition-all active:scale-95 min-h-[32px]"
            >
              Copy
            </button>
          </div>

          <!-- Send Action Button -->
          <a 
            href="mailto:support@fontconverterhub.com?subject=Font%20Converter%20Hub%20Feedback"
            class="mt-6 inline-flex items-center gap-2 px-6 py-3 text-sm font-bold text-white bg-brand-600 hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600 rounded-xl shadow-xs transition-all cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 min-h-[44px]"
          >
            <span>Send Email</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- FAQ/Information box -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs sm:text-sm text-slate-600 dark:text-slate-400">
        <div class="p-5 rounded-2xl bg-slate-100/50 dark:bg-slate-900/30 border border-slate-200/20">
          <h3 class="font-bold text-slate-900 dark:text-slate-100 mb-2">Requesting New Layouts</h3>
          <p class="leading-relaxed">
            Need DevLys, Chanakya, Shivaji, or Shusha conversion? Drop us an email with sample text files so we can add them to our upcoming releases.
          </p>
        </div>
        <div class="p-5 rounded-2xl bg-slate-100/50 dark:bg-slate-900/30 border border-slate-200/20">
          <h3 class="font-bold text-slate-900 dark:text-slate-100 mb-2">Reporting Translation Errors</h3>
          <p class="leading-relaxed">
            If a specific character, half-character (sanyukt), or vowel matra converts incorrectly, please email us the exact input and expected output.
          </p>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script>
  const setupCopyEmail = () => {
    const btn = document.getElementById('copy-email-btn');
    const emailEl = document.getElementById('email-address');

    if (!btn || !emailEl) return;

    btn.addEventListener('click', () => {
      const email = emailEl.textContent?.trim() || '';
      navigator.clipboard.writeText(email).then(() => {
        const originalText = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('text-emerald-600', 'border-emerald-500');
        
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('text-emerald-600', 'border-emerald-500');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy email: ', err);
      });
    });
  };

  setupCopyEmail();
  document.addEventListener('astro:after-swap', setupCopyEmail);
</script>
