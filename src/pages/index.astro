---
import Layout from '../layouts/Layout.astro';
import TrustStrip from '../components/TrustStrip.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';

// JSON-LD schemas for homepage SEO
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Font Converter Hub",
    "description": "Bidirectional converter between legacy Krutidev 010 typewriter fonts and standard digital Devanagari Unicode (Mangal).",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript.",
    "url": "https://fontconverterhub.com"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Font Converter Hub Suite",
    "description": "Convert legacy Krutidev font characters to Devanagari Unicode and vice versa instantly in your browser.",
    "url": "https://fontconverterhub.com",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any (Web Browser)",
    "browserRequirements": "Requires JavaScript."
  }
];

const faqs = [
  {
    q: "How does the conversion process work?",
    a: "The conversion maps legacy typewriter key combinations (like Krutidev 010) back to standard Unicode values (like Mangal font) and vice versa. It corrects character reordering, like the placing of 'chhoti-i' vowel signs and rephs, in real time."
  },
  {
    q: "Is my text data private?",
    a: "Yes. All conversion logic runs 100% locally in your web browser. No text is uploaded to any remote server, keeping your sensitive documents completely private and secure."
  },
  {
    q: "Do I need to install any fonts to view the output?",
    a: "No. Unicode Devanagari text is readable natively on all modern computers, smartphones, and web pages. However, to display the legacy Krutidev output correctly in offline editors like Microsoft Word, you must have the 'Krutidev 010' font installed on your system."
  },
  {
    q: "Does the hub support Sanskrit characters?",
    a: "Yes. It supports the full Devanagari script layout, which covers Hindi, Sanskrit, Marathi, Konkani, and Nepali languages typed in legacy or modern digital encodings."
  }
];
---

<Layout
  title="Hindi & Sanskrit Font Converter Suite"
  description="Instant bidirectional font conversion between Krutidev 010 visual typewriter fonts and Devanagari Unicode. 100% offline, private and browser-based."
  schema={schemas}
>
  <div class="pt-6 pb-12 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Compact Introduction (SECTION 1) -->
      <div class="text-center max-w-3xl mx-auto mt-4 mb-6 select-none">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight mb-3">
          Font Converter Hub
        </h1>
        <p class="text-base text-slate-600 dark:text-slate-300 leading-relaxed max-w-2xl mx-auto">
          Convert between Krutidev, Unicode and other Hindi font formats instantly. Private, browser-based and free.
        </p>
      </div>

      <!-- Tool Cards (SECTION 2) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-6">
        <!-- Card 1: Krutidev to Unicode -->
        <div class="flex flex-col border border-slate-200 dark:border-slate-800 rounded-2xl bg-white dark:bg-slate-900 p-6 shadow-sm hover:border-brand-500/50 dark:hover:border-brand-500/30 transition-all duration-200">
          <div class="flex items-center justify-between mb-4">
            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded text-[10px] font-bold bg-brand-50 dark:bg-brand-950/40 text-brand-700 dark:text-brand-400 border border-brand-200/10">
              Krutidev 010 to Unicode
            </span>
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-bold text-xs select-none">
              अ
            </span>
          </div>
          <h2 class="text-xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight mb-2 flex items-center gap-2">
            <span>Krutidev</span>
            <span class="text-slate-400 dark:text-slate-600">→</span>
            <span>Unicode</span>
          </h2>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
            Convert legacy Krutidev text into standard Unicode Devanagari.
          </p>
          <div class="mt-auto">
            <a
              href="/krutidev-to-unicode"
              class="w-full inline-flex items-center justify-center px-4 py-2.5 text-xs font-bold text-white bg-brand-600 hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600 rounded-xl shadow-xs transition-all cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 min-h-[40px]"
            >
              Open Converter
            </a>
          </div>
        </div>

        <!-- Card 2: Unicode to Krutidev -->
        <div class="flex flex-col border border-slate-200 dark:border-slate-800 rounded-2xl bg-white dark:bg-slate-900 p-6 shadow-sm hover:border-brand-500/50 dark:hover:border-brand-500/30 transition-all duration-200">
          <div class="flex items-center justify-between mb-4">
            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded text-[10px] font-bold bg-brand-50 dark:bg-brand-950/40 text-brand-700 dark:text-brand-400 border border-brand-200/10">
              Unicode to Krutidev 010
            </span>
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-bold text-xs select-none">
              क
            </span>
          </div>
          <h2 class="text-xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight mb-2 flex items-center gap-2">
            <span>Unicode</span>
            <span class="text-slate-400 dark:text-slate-600">→</span>
            <span>Krutidev</span>
          </h2>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
            Convert standard Unicode Devanagari text back to Krutidev.
          </p>
          <div class="mt-auto">
            <a
              href="/unicode-to-krutidev"
              class="w-full inline-flex items-center justify-center px-4 py-2.5 text-xs font-bold text-white bg-brand-600 hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600 rounded-xl shadow-xs transition-all cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 min-h-[40px]"
            >
              Open Converter
            </a>
          </div>
        </div>
      </div>

      <!-- Trust Strip (SECTION 3) -->
      <TrustStrip className="pb-8 border-b border-slate-200/60 dark:border-slate-800/40 max-w-5xl mx-auto" />

      <!-- Educational Content (SECTION 4) -->
      <section class="max-w-5xl mx-auto my-8 text-slate-700 dark:text-slate-300">
        <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-3">
          Hindi Font Conversion Suite
        </h2>
        <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
          This suite provides high-performance conversion tools to translate text between legacy typewriter font encodings and modern standard Unicode Devanagari. Standardizing Devanagari typography is critical for the modern web, as visual-only fonts cannot be indexed by search engines or displayed on mobile devices.
        </p>
        <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          By utilizing our offline-ready local converters, you can convert documents client-side without any security risks. This is highly useful for government workers, desktop publishers (DTP), translators, and authors dealing with legacy Krutidev font submissions.
        </p>
      </section>

      <!-- Related Converters Internal Linking -->
      <RelatedTools />

      <!-- FAQ Section (FAQ at the bottom, just above footer) -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>
