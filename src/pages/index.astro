                Unicode → KrutiDev
              </a>
            </div>
          </div>

          <!-- Card 2: KrutiDev ↔ Mangal -->
          <div class="flex flex-col border-[0.5px] border-slate-200 dark:border-slate-800/80 rounded-lg bg-white dark:bg-slate-900 p-5 shadow-2xs hover:border-brand-500/60 dark:hover:border-brand-400/60 transition-colors">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-7 h-7 shrink-0 flex items-center justify-center rounded bg-[#E1F5EE] dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-450">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
