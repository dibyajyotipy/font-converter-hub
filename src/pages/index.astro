                class="block w-full text-center py-2 px-3 bg-brand-600 hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600 text-white text-xs font-bold rounded-lg transition-colors cursor-pointer min-h-[36px]"
              >
                KrutiDev → Unicode
              </a>
              <a
                href="/unicode-to-krutidev/"
