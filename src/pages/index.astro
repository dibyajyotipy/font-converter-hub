---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';

// JSON-LD schemas for homepage SEO
const faqs = [
  {
    q: "How does the KrutiDev to Unicode conversion work?",
    a: "KrutiDev encodes each Devanagari character as a specific keyboard key. Our converter holds a complete lookup table mapping every KrutiDev key position to its correct Unicode Devanagari code point — including vowel matras, half-consonants, conjuncts, and Devanagari digits. The mapping runs entirely in your browser using JavaScript, with no server involvement."
  },
  {
    q: "Is this KrutiDev converter free to use?",
    a: "Yes — completely free, with no word limit, no login, and no paywall. All conversion tools on Font Converter Hub are and will remain free."
  },
  {
    q: "Is my Hindi text private and secure?",
    a: "Yes. Conversion runs entirely client-side in JavaScript — your text never leaves your device and is never sent to our servers or any third party. You can disconnect from the internet after the page loads and the converter will still work."
  },
  {
    q: "Does the converter handle complex Devanagari conjuncts correctly?",
    a: "Yes. The engine handles complex conjuncts like स्त्र, क्ष, ज्ञ, and त्र, correct reph (र्) placement, half-consonants, and Devanagari numerals — the cases where most basic converters produce incorrect output. It has been tested against real document text including government forms and Hindi newspaper copy."
  },
  {
    q: "What happens with English words mixed into KrutiDev text?",
    a: "Legacy fonts like KrutiDev map Devanagari characters onto the same keyboard positions as English letters — so the converter cannot tell whether a Latin \"D\" in your input is an English letter or a KrutiDev Hindi keystroke. For best results, keep English words, names, and abbreviations separate from your KrutiDev text and add them back after converting."
  },
  {
    q: "Do I need to install any fonts?",
    a: "Not to use the converter. For Unicode output (the most common case), no font installation is needed — Unicode Devanagari renders natively on all modern devices. For legacy font output like Mangal or Chanakya, you'll need that font installed in your word processor to view the result correctly after pasting."
  },
  {
    q: "Does this work for Sanskrit text too?",
    a: "Yes — the converter supports the full Devanagari character set used in KrutiDev, which covers both Hindi and Sanskrit including extended conjuncts and special characters used in Sanskrit typography."
  },
  {
    q: "Is there a character or word limit?",
    a: "No limit at all. Since conversion happens in your browser, you can paste entire documents — speed depends only on your device, not our servers."
  }
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Font Converter Hub",
    "description": "Bidirectional converter between legacy Krutidev 010 typewriter fonts and standard digital Devanagari Unicode (Mangal).",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript.",
    "url": "https://fontconverterhub.com"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Font Converter Hub Suite",
    "description": "Convert legacy Krutidev font characters to Devanagari Unicode and vice versa instantly in your browser.",
    "url": "https://fontconverterhub.com",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any (Web Browser)",
    "browserRequirements": "Requires JavaScript."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  }
];
---

