---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { CONVERTERS } from '../config/converters';

const converterInfo = CONVERTERS.find(c => c.id === 'preeti-to-unicode');
if (!converterInfo) {
  throw new Error("Converter configuration for ID 'preeti-to-unicode' not found in registry.");
}

const faqs = converterInfo.faq;

// Generate JSON-LD schemas
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Preeti to Unicode Converter — Free Online Nepali Tool",
  "description": "Convert Preeti font text to Unicode Nepali instantly. Free, online, no install needed. Paste your Preeti text and get clean Devanagari Unicode in seconds.",
  "url": new URL('/preeti-to-unicode/', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Preeti to Unicode Converter",
  "description": "Convert Preeti font text to Unicode Nepali instantly. Free, online, no install needed. Paste your Preeti text and get clean Devanagari Unicode in seconds.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "browserRequirements": "Requires JavaScript.",
  "url": new URL('/preeti-to-unicode/', Astro.site || 'https://fontconverterhub.com').href
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fontconverterhub.com/" },
    { "@type": "ListItem", "position": 2, "name": "Preeti to Unicode Converter", "item": "https://fontconverterhub.com/preeti-to-unicode/" }
  ]
};

const schemas = [pageSchema, appSchema, faqSchema, breadcrumbSchema];
---

<Layout
  title="Preeti to Unicode Converter — Free Online Nepali Tool"
  description="Convert Preeti font text to Unicode Nepali instantly. Free, online, no install needed. Paste your Preeti text and get clean Devanagari Unicode in seconds."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first, above fold) -->
      <Converter
        direction="preeti-to-unicode"
        inputPlaceholder={converterInfo.placeholders.input}
        outputPlaceholder={converterInfo.placeholders.output}
        swapTarget="/unicode-to-preeti"
        examples={converterInfo.examples}
        inputLabel="Preeti Text"
        outputLabel="Unicode (Nepali)"
      />

      <!-- Compact Utility Title and Disambiguation Notice -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          Preeti to Unicode Converter
        </h1>
        <p class="text-[13px] text-slate-500 dark:text-slate-400 mt-2 leading-normal select-text">
          Preeti is a legacy ASCII-based Nepali font widely used for drafting official documents, newspapers, and printing layouts. Because modern digital platforms, websites, and mobile devices do not natively support legacy ASCII encodings, converting your text is essential to make it readable. This free online tool converts Preeti font to clean, standard Nepali Unicode instantly in your browser without requiring any software installation.
        </p>
        
        <!-- Disambiguation Links -->
        <div class="flex gap-2.5 flex-wrap mt-5 select-text">
          <a
            href="/unicode-to-preeti/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Reverse: Unicode to Preeti
          </a>
          <a
            href="/krutidev-to-unicode/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Also need KrutiDev? KrutiDev to Unicode
          </a>
          <a
            href="/preeti-font-download/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Preeti Font
          </a>
        </div>
      </div>

      <!-- How To Use -->
      <HowToUse
        title={converterInfo.howTo.title}
        steps={converterInfo.howTo.steps}
        type={converterInfo.howTo.type}
      />

      <!-- Custom Content Sections (About Section layout) -->
      <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
        <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
          <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Detailed Guide: Preeti to Unicode Conversion
        </h2>
        <div class="text-sm text-slate-650 dark:text-slate-350 space-y-6 leading-relaxed font-normal">
          
          <!-- Section 1: What Is Preeti to Unicode Conversion? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Is Preeti to Unicode Conversion?</h3>
            <p>
              Preeti is a legacy non-Unicode Nepali font that has been widely used across Nepal in government offices, newspapers, print shops, and old DTP software since the 1990s. Like KrutiDev in India, it maps Nepali Devanagari glyphs onto English ASCII keys in a non-standard way — which means Preeti text only displays correctly if the exact Preeti font is installed. On a phone, website, or modern app without that font, the text appears as garbled English symbols.
            </p>
            <p class="mt-2.5">
              Unicode is the universal standard used by every modern device, browser, and operating system. Converting Preeti to Unicode takes that old ASCII-mapped text and rebuilds it as proper Devanagari Unicode — readable anywhere, searchable, copy-paste friendly, and compatible with any standard Unicode Nepali font.
            </p>
            <p class="mt-2.5">
              If you need the Preeti font installed to view old documents before converting, you can <a href="/preeti-font-download" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">download the Preeti font for free</a> from our resource page.
            </p>
            <p class="mt-2.5 text-xs italic text-slate-500 dark:text-slate-400">
              Note: If your Preeti text currently displays as random English letters in a plain text editor, that's expected — it just means the Preeti font isn't applied. Paste it into the tool above as-is; you don't need to "fix" it first.
            </p>
          </div>

          <!-- Section 2: How to Convert Preeti to Unicode Online -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">How to Convert Preeti to Unicode Online</h3>
            <ol class="list-decimal pl-5 space-y-2 mt-2 text-sm">
              <li>Paste your Preeti font Nepali text into the input box above — copy it directly from Word, PDF, or wherever it currently lives.</li>
              <li>Click Convert to Unicode.</li>
              <li>Copy the Unicode output — it will display correctly in any standard font, no special font needed.</li>
              <li>Paste it into Word, WhatsApp, a website, or any Unicode-compatible app.</li>
            </ol>
            <p class="mt-3">
              For multi-page documents, paste the content in batches — the tool handles multi-line text in a single pass.
            </p>
          </div>

          <!-- Section 3: Preeti vs Unicode Comparison Table -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Preeti vs Unicode — Comparison</h3>
            
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Term</th>
                    <th>What it means</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">Preeti to Unicode</td>
                    <td>Convert legacy Preeti font text → universal Unicode (Devanagari)</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Unicode to Preeti</td>
                    <td>The reverse — see our <a href="/unicode-to-preeti/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Unicode to Preeti Converter</a></td>
                  </tr>
                  <tr>
                    <td class="font-bold">Preeti vs KrutiDev</td>
                    <td>Both are legacy ASCII fonts, but Preeti is used for Nepali (Nepal) while KrutiDev is used for Hindi (India) — they use different key mappings</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Section 4: Who Needs to Convert Preeti to Unicode? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Needs to Convert Preeti to Unicode?</h3>
            <ul class="list-disc pl-5 space-y-2 mt-2 text-sm">
              <li><strong>Government and civil service staff</strong> in Nepal holding decades of old Preeti-formatted letters, memos, and records who need to digitise them into searchable, future-proof Unicode format.</li>
              <li><strong>Journalists and newspaper editors</strong> — Preeti was the dominant font across Nepali print media; this tool recovers that archived content into readable Unicode.</li>
              <li><strong>Students and typing exam candidates</strong> who learned on Preeti-based keyboards but need Unicode output for modern online forms, applications, and documents.</li>
              <li><strong>Web publishers and bloggers</strong> with old Preeti-era Nepali content that displays as broken symbols on today's websites and needs to be restored to readable Unicode for SEO and accessibility.</li>
              <li><strong>DTP and print professionals</strong> migrating old press files into modern Unicode-based workflows.</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- Related Tools -->
      <RelatedTools currentPath="/preeti-to-unicode" />

      <!-- FAQ Section -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>

<style>
  /* Custom heading spacing inside the detailed guide card */
  h3 {
    margin-top: 1.5rem;
  }
  
  /* Clean table styling matching keyboard layout page */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: rgba(248, 250, 252, 0.5);
  }
  
  .dark .font-table tr:hover {
    background-color: rgba(30, 41, 59, 0.3);
  }
</style>
