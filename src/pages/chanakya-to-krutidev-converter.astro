---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { CONVERTERS } from '../config/converters';

const converterInfo = CONVERTERS.find(c => c.id === 'chanakya-to-krutidev');
if (!converterInfo) {
  throw new Error("Converter configuration for ID 'chanakya-to-krutidev' not found in registry.");
}

const faqs = converterInfo.faq;

// Generate JSON-LD schemas
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Chanakya to KrutiDev Converter – Free Online Tool",
  "description": "Convert Chanakya Hindi text to KrutiDev 010 font online, free and instantly.",
  "url": new URL('/chanakya-to-krutidev-converter/', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Chanakya to KrutiDev Converter",
  "description": "Convert Chanakya Hindi text to KrutiDev 010 font online, free and instantly.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "browserRequirements": "Requires JavaScript.",
  "url": new URL('/chanakya-to-krutidev-converter/', Astro.site || 'https://fontconverterhub.com').href
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const schemas = [pageSchema, appSchema, faqSchema];
---

<Layout
  title="Chanakya to KrutiDev Converter – Free Online Tool"
  description="Convert Chanakya Hindi text to KrutiDev 010 font online, free and instantly."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first, above fold) -->
      <Converter
        direction="chanakya-to-krutidev"
        inputPlaceholder={converterInfo.placeholders.input}
        outputPlaceholder={converterInfo.placeholders.output}
        swapTarget="/krutidev-to-chanakya-converter"
        examples={converterInfo.examples}
        inputLabel="Chanakya Text"
        outputLabel="KrutiDev Text"
      />

      <!-- Compact Utility Title and Disambiguation Notice -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          Chanakya to KrutiDev Converter (Free, Online)
        </h1>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1.5 leading-none">
          Paste your Chanakya Hindi text below and convert it to KrutiDev (KrutiDev 010) font in one click — free, instant, and no login required. Useful for moving content from Chanakya-based newspaper and DTP systems into KrutiDev format for government forms, typing exams, and legacy workflows.
        </p>
        
        <!-- Disambiguation Links -->
        <div class="flex gap-2.5 flex-wrap mt-5 select-text">
          <a
            href="/krutidev-to-chanakya-converter/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Reverse: KrutiDev to Chanakya
          </a>
          <a
            href="/krutidev-to-unicode/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Need Unicode instead? KrutiDev to Unicode
          </a>
        </div>
      </div>

      <!-- How To Use (How to use second) -->
      <HowToUse
        title={converterInfo.howTo.title}
        steps={converterInfo.howTo.steps}
        type={converterInfo.howTo.type}
      />

      <!-- Custom Content Sections (About Section layout) -->
      <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
        <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
          <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Detailed Guide: Chanakya to KrutiDev Conversion
        </h2>
        <div class="text-sm text-slate-650 dark:text-slate-350 space-y-6 leading-relaxed font-normal">
          
          <!-- Section 1 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Is Chanakya to KrutiDev Conversion?</h3>
            <p>
              Chanakya and KrutiDev are both legacy, non-Unicode Hindi fonts that map Devanagari glyphs onto English keyboard keys — but each uses its own distinct mapping. Chanakya has been widely used in Indian newspaper and print publishing for decades, while KrutiDev is more common in government offices and typing examinations.
            </p>
            <p class="mt-2.5">
              This tool converts your Chanakya text so it displays correctly when the KrutiDev 010 font is applied, handling the character and conjunct differences between the two encodings automatically.
            </p>
            <p class="mt-2.5 text-xs italic text-slate-500 dark:text-slate-400">
              Note: After conversion, select the output text and apply the KrutiDev 010 font in your word processor to see correct Hindi — the raw output will look like unrelated English characters until the font is applied.
            </p>
          </div>

          <!-- Section 2 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">How to Convert Chanakya to KrutiDev Online</h3>
            <ol class="list-decimal pl-5 space-y-2 mt-2 text-sm">
              <li>Paste your Chanakya text into the input box above.</li>
              <li>Click Convert to KrutiDev.</li>
              <li>Copy the output text.</li>
              <li>Paste it into your document and apply the KrutiDev 010 font.</li>
              <li>Your Hindi text will now display correctly in KrutiDev format.</li>
            </ol>
          </div>

          <!-- Section 3 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Chanakya to KrutiDev vs Other Conversions</h3>
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Term</th>
                    <th>What it means</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">Chanakya to KrutiDev</td>
                    <td>Convert legacy Chanakya text &rarr; KrutiDev 010 font encoding</td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev to Chanakya</td>
                    <td>The reverse — see our <a href="/krutidev-to-chanakya-converter/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">KrutiDev to Chanakya Converter</a></td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev to Unicode</td>
                    <td>A different conversion — universal Unicode. See our <a href="/krutidev-to-unicode/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">KrutiDev to Unicode Converter</a></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Section 4 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Needs to Convert Chanakya to KrutiDev?</h3>
            <ul class="list-disc pl-5 space-y-2 mt-2 text-sm">
              <li><strong>Government employees and clerks</strong> who receive typed materials, articles, or books in legacy Chanakya format from external designers or publishers but must submit the files in standard KrutiDev 010 format to meet administrative guidelines or portal submission rules.</li>
              <li><strong>DTP operators and publishers</strong> who work with mixed legacy print files, converting older media layout elements (often styled in Chanakya for publishing presses) back to KrutiDev for compatibility with typing examinations, local offices, or general documentation.</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- Related Tools -->
      <RelatedTools currentPath="/chanakya-to-krutidev-converter" />

      <!-- FAQ Section (Reusing FAQ component) -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>

<style>
  /* Custom heading spacing inside the detailed guide card */
  h3 {
    margin-top: 1.5rem;
  }
  
  /* Clean table styling matching keyboard layout page */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: rgba(248, 250, 252, 0.5);
  }
  
  .dark .font-table tr:hover {
    background-color: rgba(30, 41, 59, 0.3);
  }
</style>
