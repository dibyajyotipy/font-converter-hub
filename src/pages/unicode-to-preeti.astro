---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { CONVERTERS } from '../config/converters';

const converterInfo = CONVERTERS.find(c => c.id === 'unicode-to-preeti');
if (!converterInfo) {
  throw new Error("Converter configuration for ID 'unicode-to-preeti' not found in registry.");
}

const faqs = converterInfo.faq;

// Generate JSON-LD schemas
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Unicode to Preeti Converter — Free Nepali Font Tool",
  "description": "Convert Unicode Nepali text to Preeti font encoding online. Free, instant, browser-based. Perfect for legacy Nepali DTP, newspapers, and government document workflows.",
  "url": new URL('/unicode-to-preeti/', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Unicode to Preeti Font Converter",
  "description": "Convert Unicode Nepali text to Preeti font encoding online. Free, instant, browser-based. Perfect for legacy Nepali DTP, newspapers, and government document workflows.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "browserRequirements": "Requires JavaScript.",
  "url": new URL('/unicode-to-preeti/', Astro.site || 'https://fontconverterhub.com').href
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fontconverterhub.com/" },
    { "@type": "ListItem", "position": 2, "name": "Unicode to Preeti Font Converter", "item": "https://fontconverterhub.com/unicode-to-preeti/" }
  ]
};

const schemas = [pageSchema, appSchema, faqSchema, breadcrumbSchema];
---

<Layout
  title="Unicode to Preeti Converter — Free Nepali Font Tool"
  description="Convert Unicode Nepali text to Preeti font encoding online. Free, instant, browser-based. Perfect for legacy Nepali DTP, newspapers, and government document workflows."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first, above fold) -->
      <Converter
        direction="unicode-to-preeti"
        inputPlaceholder={converterInfo.placeholders.input}
        outputPlaceholder={converterInfo.placeholders.output}
        swapTarget="/preeti-to-unicode"
        examples={converterInfo.examples}
        inputLabel="Unicode (Nepali)"
        outputLabel="Preeti Text"
      />

      <!-- Compact Utility Title and Disambiguation Notice -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          Unicode to Preeti Font Converter
        </h1>
        <p class="text-[13px] text-slate-500 dark:text-slate-400 mt-2 leading-normal select-text">
          Need to paste modern Nepali text into an old PageMaker layout, an InDesign template, or a Word document that uses the Preeti font? This free Unicode to Preeti font converter handles it instantly. Type or paste any Nepali Unicode text — whether copied from a website, typed on your phone, or received via email — and get Preeti-encoded output ready for your legacy DTP or print workflow. The conversion from Nepali Unicode to Preeti runs entirely in your browser with no sign-up or download required.
        </p>
        
        <!-- Disambiguation Links -->
        <div class="flex gap-2.5 flex-wrap mt-5 select-text">
          <a
            href="/preeti-to-unicode/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Reverse: Preeti to Unicode
          </a>
          <a
            href="/unicode-to-krutidev/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Need KrutiDev? Unicode to KrutiDev
          </a>
          <a
            href="/preeti-font-download/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Preeti Font
          </a>
        </div>
      </div>

      <!-- How To Use -->
      <HowToUse
        title={converterInfo.howTo.title}
        steps={converterInfo.howTo.steps}
        type={converterInfo.howTo.type}
      />

      <!-- Custom Content Sections (About Section layout) -->
      <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
        <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
          <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Detailed Guide: Unicode to Preeti Font Conversion
        </h2>
        <div class="text-sm text-slate-650 dark:text-slate-350 space-y-6 leading-relaxed font-normal">
          
          <!-- Section 1: What Is Unicode to Preeti Conversion? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Is Unicode to Preeti Font Conversion?</h3>
            <p>
              Unicode is the universal text encoding standard used by every modern phone, browser, and operating system. When you type Nepali on any modern device, you produce Unicode text. Preeti, on the other hand, is a legacy non-Unicode font still required by many Nepali government offices, newspaper publishing systems, and DTP software — it maps Nepali Devanagari glyphs onto English ASCII character positions in a proprietary way.
            </p>
            <p class="mt-2.5">
              If you need the Preeti font installed on your system to view the visual layout or format documents, you can <a href="/preeti-font-download" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">download Preeti font for free</a> from our resources.
            </p>
            <p class="mt-2.5">
              This Unicode to Preeti font converter takes your standard Nepali Unicode text and re-encodes it into the Preeti character mapping — including correct repositioning of matras and the reph (र्) marker, which occupies a different position in Preeti than in Unicode. The result is text you can paste directly into PageMaker, InDesign, CorelDraw, or Word and display correctly by setting the font to Preeti.
            </p>
            <p class="mt-2.5 text-xs italic text-slate-500 dark:text-slate-400">
              Note: The converted output will appear as seemingly random English characters in a standard text editor. This is expected — select the text and change the font to Preeti in your word processor or DTP application to see the correct Nepali rendering.
            </p>
          </div>

          <!-- Section 2: How to Use the Converted Preeti Output -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">How to Use the Converted Preeti Output</h3>
            <ol class="list-decimal pl-5 space-y-2 mt-2 text-sm">
              <li>Type or paste your Unicode Nepali text — from a website, phone keyboard, email, or any modern source — into the input box above.</li>
              <li>The Preeti-encoded text appears instantly in the output area on the right.</li>
              <li>Click <strong>Copy</strong> to copy the Preeti output to your clipboard.</li>
              <li>Open your target application (Word, PageMaker, InDesign, CorelDraw), paste the text, and set the font to <strong>Preeti</strong>.</li>
              <li>Your Nepali text will now render correctly in the Preeti font format expected by your legacy workflow.</li>
            </ol>
          </div>

          <!-- Section 3: Software Compatibility Table -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Software Compatibility</h3>
            <p>
              The Preeti font encoding produced by this converter is compatible with all major Nepali DTP and document software. Here is a quick reference:
            </p>
            
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Application</th>
                    <th>How to Use</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">Microsoft Word</td>
                    <td>Paste output → select text → choose "Preeti" from font dropdown</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Adobe PageMaker</td>
                    <td>Paste into text frame → apply Preeti font via Type menu</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Adobe InDesign</td>
                    <td>Place text in frame → set Character panel font to Preeti</td>
                  </tr>
                  <tr>
                    <td class="font-bold">CorelDraw</td>
                    <td>Paste into text object → select Preeti from font list</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Other Nepali DTP</td>
                    <td>Paste and apply Preeti font — standard encoding works everywhere</td>
                  </tr>
                </tbody>
              </table>
            </div>
            
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-2">
              Don't have the Preeti font installed? <a href="/preeti-font-download/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Download Preeti font free</a> from our font library.
            </p>
          </div>

          <!-- Section 4: Who Needs Unicode to Preeti Conversion? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Needs to Convert Nepali Unicode to Preeti?</h3>
            <ul class="list-disc pl-5 space-y-2 mt-2 text-sm">
              <li><strong>Government offices and civil servants</strong> who draft documents in modern Unicode Nepali but must submit final files to legacy administrative systems that only accept Preeti-formatted text.</li>
              <li><strong>Newspaper and print media professionals</strong> whose publishing pipelines — built around PageMaker or InDesign — were set up decades ago with Preeti and haven't been migrated to Unicode.</li>
              <li><strong>DTP operators and graphic designers</strong> in Nepali print shops working with templates, certificates, and layouts that expect Preeti font encoding rather than Unicode.</li>
              <li><strong>Data entry workers and typists</strong> who receive modern Unicode content (from websites, emails, or mobile devices) but need to enter it into older database systems or forms that only support Preeti.</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- Related Tools -->
      <RelatedTools currentPath="/unicode-to-preeti" />

      <!-- FAQ Section -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>

<style>
  /* Custom heading spacing inside the detailed guide card */
  h3 {
    margin-top: 1.5rem;
  }
  
  /* Clean table styling matching keyboard layout page */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: rgba(248, 250, 252, 0.5);
  }
  
  .dark .font-table tr:hover {
    background-color: rgba(30, 41, 59, 0.3);
  }
</style>
