---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { CONVERTERS } from '../config/converters';

const converterInfo = CONVERTERS.find(c => c.id === 'krutidev-to-chanakya');
if (!converterInfo) {
  throw new Error("Converter configuration for ID 'krutidev-to-chanakya' not found in registry.");
}

const faqs = converterInfo.faq;

// Generate JSON-LD schemas
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "KrutiDev to Chanakya Converter – Free Online Tool",
  "description": "Convert KrutiDev 010 Hindi text to Chanakya font online, free and instantly. Paste your KrutiDev text and get Chanakya-formatted output ready for print, DTP, and legacy publishing systems.",
  "url": new URL('/krutidev-to-chanakya-converter/', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "KrutiDev to Chanakya Converter",
  "description": "Convert KrutiDev 010 Hindi text to Chanakya font online, free and instantly. Paste your KrutiDev text and get Chanakya-formatted output ready for print, DTP, and legacy publishing systems.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "browserRequirements": "Requires JavaScript.",
  "url": new URL('/krutidev-to-chanakya-converter/', Astro.site || 'https://fontconverterhub.com').href
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const schemas = [pageSchema, appSchema, faqSchema];
---

<Layout
  title="KrutiDev to Chanakya Converter – Free Online Tool"
  description="Convert KrutiDev 010 Hindi text to Chanakya font online, free and instantly. Paste your KrutiDev text and get Chanakya-formatted output ready for print, DTP, and legacy publishing systems."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first, above fold) -->
      <Converter
        direction="krutidev-to-chanakya"
        inputPlaceholder={converterInfo.placeholders.input}
        outputPlaceholder={converterInfo.placeholders.output}
        swapTarget="/chanakya-to-krutidev-converter"
        examples={converterInfo.examples}
        inputLabel="KrutiDev Text"
        outputLabel="Chanakya Text"
      />

      <!-- Compact Utility Title and Disambiguation Notice -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          KrutiDev to Chanakya Converter (Free, Online)
        </h1>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1.5 leading-none">
          Paste your KrutiDev (KrutiDev 010) Hindi text below and convert it to Chanakya font in one click — free, instant, and no login required. Useful for print shops, newspaper publishing, and DTP software still set up around Chanakya font.
        </p>
        
        <!-- Disambiguation Links -->
        <div class="flex gap-2.5 flex-wrap mt-5 select-text">
          <a
            href="/chanakya-to-krutidev-converter/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Reverse: Chanakya to KrutiDev
          </a>
          <a
            href="/krutidev-to-unicode/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Need Unicode instead? KrutiDev to Unicode
          </a>
        </div>
      </div>

      <!-- How To Use (How to use second) -->
      <HowToUse
        title={converterInfo.howTo.title}
        steps={converterInfo.howTo.steps}
        type={converterInfo.howTo.type}
      />

      <!-- Custom Content Sections (About Section layout) -->
      <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
        <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
          <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Detailed Guide: KrutiDev to Chanakya Conversion
        </h2>
        <div class="text-sm text-slate-650 dark:text-slate-350 space-y-6 leading-relaxed font-normal">
          
          <!-- Section 1 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Is KrutiDev to Chanakya Conversion?</h3>
            <p>
              KrutiDev and Chanakya are both legacy, non-Unicode Hindi fonts that map Devanagari glyphs onto English keyboard keys — but each uses its own distinct mapping, so KrutiDev text doesn't display correctly if you simply apply the Chanakya font to it, or vice versa. Chanakya in particular has been widely used in Indian newspaper and print publishing for decades, alongside KrutiDev in government and exam contexts.
            </p>
            <p class="mt-2.5">
              This tool converts your KrutiDev text so it displays correctly when the Chanakya font is applied, handling the character and conjunct differences between the two encodings automatically.
            </p>
            <p class="mt-2.5 text-xs italic text-slate-500 dark:text-slate-400">
              Note: After conversion, select the output text and apply the Chanakya font in your word processor or DTP software to see correct Hindi — the raw output will look like unrelated English characters until the font is applied, same as with KrutiDev.
            </p>
          </div>

          <!-- Section 2 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">How to Convert KrutiDev to Chanakya Online</h3>
            <ol class="list-decimal pl-5 space-y-2 mt-2 text-sm">
              <li>Paste your KrutiDev text into the input box above.</li>
              <li>Click Convert to Chanakya.</li>
              <li>Copy the output text.</li>
              <li>Paste it into your document and apply the Chanakya font.</li>
              <li>Your Hindi text will now display correctly in Chanakya format.</li>
            </ol>
          </div>

          <!-- Section 3 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">KrutiDev to Chanakya vs Other Conversions</h3>
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Term</th>
                    <th>What it means</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">KrutiDev to Chanakya</td>
                    <td>Convert legacy KrutiDev text &rarr; Chanakya font encoding</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Chanakya to KrutiDev</td>
                    <td>The reverse — see our <a href="/chanakya-to-krutidev-converter/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Chanakya to KrutiDev Converter</a></td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev to Unicode</td>
                    <td>A different conversion — universal Unicode, not Chanakya. See our <a href="/krutidev-to-unicode/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">KrutiDev to Unicode Converter</a></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Section 4 -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Needs to Convert KrutiDev to Chanakya?</h3>
            <ul class="list-disc pl-5 space-y-2 mt-2 text-sm">
              <li><strong>Newspaper and print publishers</strong> whose DTP and layout software (often older PageMaker/CorelDraw setups) is configured around Chanakya font specifically.</li>
              <li><strong>DTP operators</strong> handling mixed legacy files where some content arrives in KrutiDev and needs to match Chanakya-formatted layouts already in use.</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- Related Tools -->
      <RelatedTools currentPath="/krutidev-to-chanakya-converter" />

      <!-- FAQ Section (Reusing FAQ component) -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>

<style>
  /* Custom heading spacing inside the detailed guide card */
  h3 {
    margin-top: 1.5rem;
  }
  
  /* Clean table styling matching keyboard layout page */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: rgba(248, 250, 252, 0.5);
  }
  
  .dark .font-table tr:hover {
    background-color: rgba(30, 41, 59, 0.3);
  }
</style>
