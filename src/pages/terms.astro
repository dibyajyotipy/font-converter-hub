---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Terms of Use' },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Use - Font Converter Hub",
  "description": "Terms of use policy for Font Converter Hub, including tool limitations, verification guidelines, and liability disclaimer.",
  "url": new URL('/terms', Astro.site || 'https://fontconverterhub.com').href
};
---

<Layout
  title="Terms of Use"
  description="Terms of Use for Font Converter Hub. Read about our as-is tool terms, conversion accuracy recommendations, and limitation of liability."
  schema={schema}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbs} />

      <!-- Hero Section -->
      <div class="text-center mt-6 mb-12">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-brand-50 dark:bg-brand-950/40 text-brand-700 dark:text-brand-400 border border-brand-200/10 mb-4">
          Usage Guidelines
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight mb-4">
          Terms of Use
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 leading-relaxed max-w-xl mx-auto">
          Please review the terms of using Font Converter Hub. By accessing our tools, you agree to these straightforward guidelines.
        </p>
      </div>

      <!-- Content Container -->
      <div class="border border-slate-200/60 dark:border-slate-800/60 rounded-2xl bg-white dark:bg-slate-900 p-6 sm:p-10 shadow-xs mb-8 space-y-8 text-slate-600 dark:text-slate-300">
        
        <!-- Provided As-Is -->
        <section class="space-y-2">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-950/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              Service Provided "As-Is"
            </h2>
          </div>
          <p class="text-sm leading-relaxed pl-10">
            Font Converter Hub is a free developer utility. All text conversion features, tools, and visual displays are provided "as-is" and "as-available" without warranties of any kind, either express or implied, including but not limited to suitability for a specific task.
          </p>
        </section>

        <!-- No Guarantee of Accuracy -->
        <section class="space-y-2">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-950/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              No Guarantee of Conversion Accuracy
            </h2>
          </div>
          <p class="text-sm leading-relaxed pl-10">
            While we continuously test and improve our character-mapping algorithms, Devanagari script conversions (especially concerning complex joint-letters, matras, and half-consonants) may occasionally contain rendering variations or errors. We do not guarantee 100% conversion accuracy.
          </p>
        </section>

        <!-- Verify Converted Text -->
        <section class="space-y-2">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-8 h-8 rounded-lg bg-brand-50 dark:bg-brand-950/50 flex items-center justify-center text-brand-600 dark:text-brand-400">
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              Responsibility to Verify Output
            </h2>
          </div>
          <p class="text-sm leading-relaxed pl-10">
            It is the user's sole responsibility to proofread and verify the accuracy of all converted text prior to publishing, printing, submitting to government portals, or using it in commercial work.
          </p>
        </section>

        <!-- Limitation of Liability -->
        <section class="space-y-2">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-8 h-8 rounded-lg bg-brand-50 dark:bg-brand-950/50 flex items-center justify-center text-brand-600 dark:text-brand-400">
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              Limitation of Liability
            </h2>
          </div>
          <p class="text-sm leading-relaxed pl-10">
            Under no circumstances shall Font Converter Hub, its developers, or contributors be held liable for any direct, indirect, incidental, or consequential damages (including, but not limited to, loss of data, typesetting errors, project delays, or financial losses) arising out of the use or inability to use this site.
          </p>
        </section>

        <!-- Allowed Usage -->
        <section class="space-y-2">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-950/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
              Acceptable & Commercial Use
            </h2>
          </div>
          <p class="text-sm leading-relaxed pl-10">
            You are fully permitted to use the text generated by this website for any personal, educational, governmental, or commercial projects without attribution or fees.
          </p>
        </section>

        <!-- Contact info -->
        <section class="pt-4 border-t border-slate-100 dark:border-slate-800/60 text-xs text-slate-500 dark:text-slate-400 text-center">
          If you encounter mapping issues or have questions regarding these terms, please contact us via 
          <a href="/contact" class="text-brand-600 dark:text-brand-400 hover:underline">support@fontconverterhub.com</a>.
        </section>

      </div>

    </div>
  </div>
</Layout>
