---
import Layout from '../layouts/Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { CONVERTERS } from '../config/converters';

const converterInfo = CONVERTERS.find(c => c.id === 'unicode-to-krutidev');
if (!converterInfo) {
  throw new Error("Converter configuration for ID 'unicode-to-krutidev' not found in registry.");
}

const faqs = converterInfo.faq;

// Generate JSON-LD schemas
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Unicode to KrutiDev Converter – Free Online Tool (KrutiDev 010)",
  "description": "Convert Unicode (Mangal) Hindi text to KrutiDev 010 font online, free and instantly. Paste your Unicode text and get KrutiDev-formatted output ready for government forms, print, and typing exams.",
  "url": new URL('/unicode-to-krutidev/', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Unicode to KrutiDev Converter",
  "description": "Convert Unicode (Mangal) Hindi text to KrutiDev 010 font online, free and instantly. Paste your Unicode text and get KrutiDev-formatted output.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "browserRequirements": "Requires JavaScript.",
  "url": new URL('/unicode-to-krutidev/', Astro.site || 'https://fontconverterhub.com').href
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fontconverterhub.com/" },
    { "@type": "ListItem", "position": 2, "name": "Unicode to KrutiDev Converter", "item": "https://fontconverterhub.com/unicode-to-krutidev/" }
  ]
};

const schemas = [pageSchema, appSchema, faqSchema, breadcrumbSchema];
---

<Layout
  title="Unicode to KrutiDev Converter – Free Online Tool (KrutiDev 010)"
  description="Convert Unicode (Mangal) Hindi text to KrutiDev 010 font online, free and instantly. Paste your Unicode text and get KrutiDev-formatted output ready for government forms, print, and typing exams."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first, above fold) -->
      <Converter
        direction="unicode-to-krutidev"
        inputPlaceholder={converterInfo.placeholders.input}
        outputPlaceholder={converterInfo.placeholders.output}
        swapTarget="/krutidev-to-unicode"
        examples={converterInfo.examples}
        inputLabel="Unicode Text (Mangal)"
        outputLabel="KrutiDev Text (010)"
      />

      <!-- Compact Utility Title and Disambiguation Notice -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          Unicode to KrutiDev Converter (Free, Online, KrutiDev 010)
        </h1>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1.5 leading-none">
          Paste your Unicode (Mangal) Hindi text below and convert it to KrutiDev 010 font in one click — free, instant, and no login required. This tool outputs KrutiDev 010, the standard and most widely used version, compatible with government forms, typing exams, legacy print software, and most systems that ask for "KrutiDev" without specifying a version number.
        </p>
        
        <!-- Disambiguation Links -->
        <div class="flex gap-2.5 flex-wrap mt-5 select-text">
          <a
            href="/krutidev-to-unicode/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            Reverse: KrutiDev to Unicode
          </a>
          <a
            href="/krutidev-to-chanakya-converter/"
            class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg border border-slate-200 hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700 text-[13px] font-medium text-slate-600 hover:text-slate-900 dark:text-slate-350 dark:hover:text-slate-100 bg-slate-50 hover:bg-slate-100 dark:bg-slate-900/50 dark:hover:bg-slate-900 transition-all duration-200 active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/20 select-none no-underline"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Need Chanakya? KrutiDev to Chanakya
          </a>
        </div>
      </div>

      <!-- How To Use (How to use second) -->
      <HowToUse
        title={converterInfo.howTo.title}
        steps={converterInfo.howTo.steps}
        type={converterInfo.howTo.type}
      />

      <!-- Custom Content Sections (About Section layout) -->
      <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
        <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
          <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Detailed Guide: Unicode to KrutiDev Conversion
        </h2>
        <div class="text-sm text-slate-650 dark:text-slate-350 space-y-6 leading-relaxed font-normal">
          
          <!-- Section 1: What Is Unicode to KrutiDev Conversion? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">What Is Unicode to KrutiDev Conversion?</h3>
            <p>
              Unicode is the universal text standard used by every modern device, browser, and operating system — when you type Hindi in Mangal, Nirmala UI, or any standard keyboard, you're typing in Unicode. KrutiDev is a legacy non-Unicode font that has been used in Indian government offices, courts, print shops, and typing exams since the 1990s, and it remains a required format for several older systems.
            </p>
            <p class="mt-2.5">
              This tool maps every Unicode character from your text to its matching KrutiDev 010 encoding — including correct repositioning of ikar (ि) and reph (र्), which must appear in a different order in KrutiDev than they do in Unicode.
            </p>
            <p class="mt-2.5 text-xs italic text-slate-500 dark:text-slate-400">
              Note: After conversion, your output will appear as random-looking English characters in a plain text editor. This is normal — you need to select the output text and change the font to KrutiDev 010 in your word processor to see correct Hindi. <a href="/krutidev-font-download/" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Download KrutiDev font free &rarr;</a> For typing key positions, view our <a href="/krutidev-keyboard-layout" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">KrutiDev keyboard layout chart</a>.
            </p>
          </div>

          <!-- Section 2: Which KrutiDev Version Does This Convert To? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Which KrutiDev Version Does This Convert To?</h3>
            <p>
              This converter outputs KrutiDev 010, the most common and widely required version across Indian government and typing-exam systems. If a form or office simply says "KrutiDev" without a number, it almost always means 010.
            </p>
            <p class="mt-2.5">
              That said, KrutiDev isn't a single standard — versions like 055, 011, and 016 use slightly different key mappings for certain conjunct characters, so KrutiDev 010 output is not guaranteed to display correctly if a system specifically requires one of those other versions. If you know you need a non-010 version, check with whoever is requesting the document before submitting.
            </p>
            
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Version</th>
                    <th>Notes</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">KrutiDev 010</td>
                    <td>Most common — this converter's output, default for most government/exam use</td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev 055</td>
                    <td>Different conjunct mapping — used by some specific offices/software</td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev 016</td>
                    <td>Different conjunct mapping — less common</td>
                  </tr>
                  <tr>
                    <td class="font-bold">KrutiDev 011</td>
                    <td>Variant layout — check compatibility before using</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <p class="mt-2.5">
              This also applies if your source text was typed in Arial Unicode MS rather than Mangal — both are standard Unicode fonts under the hood, so the conversion works identically either way.
            </p>
          </div>

          <!-- Section 3: How to Convert Unicode to KrutiDev Online -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">How to Convert Unicode to KrutiDev Online</h3>
            <ol class="list-decimal pl-5 space-y-2 mt-2 text-sm">
              <li>Type or paste your Unicode Hindi text (from Mangal, Nirmala UI, or any standard Hindi keyboard) into the input box above.</li>
              <li>Click <strong>Convert to KrutiDev</strong>.</li>
              <li>Copy the output text from the KrutiDev box.</li>
              <li>Open your Word document, paste the text, and change the font to <strong>KrutiDev 010</strong>.</li>
              <li>Your Hindi text will now display correctly in KrutiDev format.</li>
            </ol>
            <p class="mt-3">
              You can also download the converted text as a .doc Word file directly, or share it via WhatsApp or email using the buttons below the converter.
            </p>
          </div>

          <!-- Section 4: Who Needs to Convert Unicode to KrutiDev? -->
          <div>
            <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">Who Needs to Convert Unicode to KrutiDev?</h3>
            <ul class="list-disc pl-5 space-y-2 mt-2 text-sm">
              <li><strong>Government employees and civil servants</strong> who draft letters, memos, and notices in modern Unicode-based software but must submit files to legacy administrative systems that only accept KrutiDev.</li>
              <li><strong>Typing exam candidates</strong> preparing for SSC, state government, high court, or other typing tests that require KrutiDev 010 format, even though they may type and practice in Unicode.</li>
              <li><strong>Print shop and DTP professionals</strong> whose design software was set up for KrutiDev years ago and hasn't been migrated to Unicode workflows.</li>
              <li><strong>Marathi and Hindi typists</strong> converting modern Unicode documents back into KrutiDev for older office systems still in use across Maharashtra and other states.</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- Related Tools -->
      <RelatedTools currentPath="/unicode-to-krutidev" />

      <!-- FAQ Section (Reusing FAQ component) -->
      <FAQ items={faqs} />

    </div>
  </div>
</Layout>

<style>
  /* Custom heading spacing inside the detailed guide card */
  h3 {
    margin-top: 1.5rem;
  }
  
  /* Clean table styling matching keyboard layout page */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: rgba(248, 250, 252, 0.5);
  }
  
  .dark .font-table tr:hover {
    background-color: rgba(30, 41, 59, 0.3);
  }
</style>
