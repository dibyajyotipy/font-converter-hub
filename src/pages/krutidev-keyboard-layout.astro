---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import TrustStrip from '../components/TrustStrip.astro';
import RelatedTools from '../components/RelatedTools.astro';
import { Image } from 'astro:assets';
import keyboardLayoutImage from '../assets/krutidev-keyboard-layout.webp';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'KrutiDev Keyboard Layout' },
];

const faqs = [
  {
    q: "What is the KrutiDev keyboard used for?",
    a: "The KrutiDev keyboard is used for typing Hindi and Marathi text in Devanagari script using a standard English QWERTY keyboard. It is the primary layout required for government typing exams and legal documentation in India."
  },
  {
    q: "Is the KrutiDev keyboard free to use?",
    a: "Yes. The KrutiDev keyboard layout chart and font are completely free to view, download, and use for typing practice, examinations, and commercial work."
  },
  {
    q: "How do I practice KrutiDev typing?",
    a: "Download the KrutiDev keyboard chart from this page to use as a reference. You can practice using online typing tests or offline typing tutor software (like Sony Typing Tutor or JR Typing Tutor) with sample Hindi paragraphs."
  },
  {
    q: "Is KrutiDev still used today?",
    a: "Yes. Even though Unicode fonts (like Mangal) are the modern digital standard for websites and mobile phones, KrutiDev remains the mandatory typing layout for many typing speed tests, state government exams, and court record systems."
  },
  {
    q: "What is KrutiDev 010 Hindi typing keyboard?",
    a: "KrutiDev 010 is the standard and most popular variant of the KrutiDev font family. The typing layout is based on the Remington typewriter mapping, where each key represents a specific Hindi character visual glyph."
  },
  {
    q: "Which keyboard is best for Hindi typing?",
    a: "For general internet use, email, and mobile messaging, Unicode keyboards (like Google Indic Keyboard or Inscript layout) are best. However, for government typing exams, KrutiDev layout is the standard and must be learned."
  }
];

// Generate JSON-LD FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "KrutiDev Keyboard Layout Chart – Free Download (Hindi/Marathi)",
  "description": "View and download the complete KrutiDev keyboard layout chart for Hindi & Marathi typing. Learn key mappings for KrutiDev 010, practice typing, and get the font too.",
  "url": new URL('/krutidev-keyboard-layout', Astro.site || 'https://fontconverterhub.com').href,
  "publisher": {
    "@type": "Organization",
    "name": "Font Converter Hub",
    "url": "https://fontconverterhub.com",
    "logo": "https://fontconverterhub.com/favicon.svg"
  }
};

const schemas = [pageSchema, faqSchema];
---

<Layout
  title="KrutiDev Keyboard Layout Chart – Free Download (Hindi/Marathi)"
  description="View and download the complete KrutiDev keyboard layout chart for Hindi & Marathi typing. Learn key mappings for KrutiDev 010, practice typing, and get the font too."
  schema={schemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5">
    <div class="download-container px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbs} />

      <!-- Main Content Card -->
      <div class="border border-slate-200/60 dark:border-slate-800/60 rounded-2xl bg-white dark:bg-slate-900 p-6 sm:p-10 shadow-xs mt-6 mb-10">
        
        <!-- H1 Hero Header -->
        <div class="text-center mb-8">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-orange-50 dark:bg-orange-950/40 text-orange-700 dark:text-orange-400 border border-orange-200/10 mb-4 select-none">
            ⌨ Remington Layout Map
          </span>
          <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight leading-tight mb-4">
            KrutiDev Keyboard Layout Chart (Free Download)
          </h1>
          <p class="text-sm sm:text-base text-slate-650 dark:text-slate-350 leading-relaxed max-w-2xl mx-auto">
            The <strong>krutidev keyboard</strong> uses a non-Unicode Remington key layout, meaning keys map to visual Hindi symbols instead of universal codes. Study our mapping chart below, download the high-resolution layout chart (PNG), and learn typing rules.
          </p>
        </div>

        <!-- Prominent Keyboard Layout Image Display -->
        <div class="my-8 flex flex-col items-center">
          <div class="relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 shadow-sm max-w-full">
            <Image
              src={keyboardLayoutImage}
              alt="KrutiDev keyboard layout chart Hindi Marathi"
              class="w-full h-auto object-cover max-h-[480px] hover:scale-101 transition-transform duration-300"
              width={900}
              height={635}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          
          <!-- Download Button -->
          <div class="mt-6 flex flex-col items-center">
            <a
              href="/krutidev-keboard-layout.png"
              download="krutidev-keyboard-layout.png"
              class="download-btn group"
              aria-label="Download KrutiDev keyboard layout chart image"
            >
              <svg class="w-5 h-5 mr-2 -ml-1 text-white group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              ⬇ Download Keyboard Chart (PNG)
            </a>
            <span class="text-xs text-slate-500 dark:text-slate-400 mt-2.5">
              High Resolution Image | Format: PNG | Size: 950 KB
            </span>
          </div>
        </div>

        <!-- TrustStrip -->
        <TrustStrip className="my-6 border-b border-slate-200/60 dark:border-slate-800/40 pb-6" />

        <!-- Educational Sections -->
        <div class="space-y-10 text-slate-650 dark:text-slate-350">
          
          <!-- What is the KrutiDev Keyboard Used For? -->
          <section>
            <h2>What is the KrutiDev Keyboard Used For?</h2>
            <p>
              The <strong>krutidev font keyboard</strong> maps Devanagari script glyphs onto English (QWERTY) keyboard layouts. It mimics traditional Indian Remington typewriters, which typists used for decades. This layout is the mandatory standard for:
            </p>
            <ul class="list-disc pl-5 space-y-2 mt-3 text-sm">
              <li><strong>Government Exams:</strong> Speed typing tests conducted by SSC CGL, CHSL, Railways, police forces, and state public service commissions (PSCs) require candidates to type using KrutiDev 010.</li>
              <li><strong>Judiciary and Law:</strong> Court transcripts, briefs, and official legal papers typed in Hindi are frequently typed in KrutiDev.</li>
              <li><strong>Desktop Publishing (DTP):</strong> Local books, newspapers, and printing houses rely on this mapping for offline typing in MS Word, PageMaker, and InDesign.</li>
            </ul>
            <p class="mt-3">
              Once you've typed or received KrutiDev text, convert it to modern Unicode using our <a href="/krutidev-to-unicode" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">KrutiDev to Unicode converter</a>, or convert it to <a href="/krutidev-to-mangal-converter" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Mangal font</a> for government portals.
            </p>
          </section>

          <!-- KrutiDev Keyboard Layout for Marathi Typing -->
          <section>
            <h2>KrutiDev Keyboard Layout for Marathi Typing</h2>
            <p>
              Because Marathi uses the same Devanagari script layout as Hindi, the KrutiDev key mapping is identical. Pressing keys maps to the same Devanagari base characters and vowel matras in both languages. Typing instructors in Maharashtra frequently utilize "krutidev keyboard marathi" layout charts to train students for local government clerical positions.
            </p>
          </section>

          <!-- How to Type in KrutiDev (Basic Rules) -->
          <section>
            <h2>How to Type in KrutiDev (Basic Rules)</h2>
            <p>
              Since KrutiDev maps visual glyphs to standard keys, typing is not phonetic. For example:
            </p>
            <ul class="list-disc pl-5 space-y-2.5 mt-3 text-sm">
              <li>Pressing <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-slate-100 dark:bg-slate-850">d</code> types the base letter <strong class="text-slate-900 dark:text-slate-100">क</strong>.</li>
              <li>Pressing <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-slate-100 dark:bg-slate-850">k</code> maps to the vowel sign <strong class="text-slate-900 dark:text-slate-100">ा</strong>.</li>
              <li>Pressing <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-slate-100 dark:bg-slate-850">f</code> maps to the chhoti-ee sign <strong class="text-slate-900 dark:text-slate-100">ि</strong>.</li>
            </ul>
            <p class="mt-4">
              To practice typing in KrutiDev:
            </p>
            <ol class="list-decimal pl-5 space-y-2 mt-2.5 text-sm">
              <li>Download the font file onto your system (install it for all users).</li>
              <li>Restart your word processor (like Microsoft Word or Excel).</li>
              <li>Select <strong>"Kruti Dev 010"</strong> as the active font.</li>
              <li>Keep our layout chart open on your screen (or print it out) to refer to key assignments.</li>
              <li>Practice typing common letter clusters and shifts to build muscle memory.</li>
            </ol>
            <p class="mt-3">
              Don't have the font yet? <a href="/krutidev-font-download" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Download the KrutiDev font</a> first, then come back to practice with this layout chart.
            </p>
          </section>

          <!-- KrutiDev 010 vs Other Variants -->
          <section>
            <h2>KrutiDev 010 vs Other Variants</h2>
            <p>
              While 010 is the dominant version, several other variations exist. Spacings and line weights differ slightly:
            </p>
            
            <div class="overflow-x-auto my-4 border border-slate-200 dark:border-slate-800 rounded-xl">
              <table class="font-table">
                <thead>
                  <tr>
                    <th>Variant</th>
                    <th>Keyboard Layout Details</th>
                    <th>Optimal Application</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="font-bold">Kruti Dev 010</td>
                    <td>Standard typewriter Remington layout.</td>
                    <td>Government typing exams, court papers, and standard practice.</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Kruti Dev 011</td>
                    <td>Identical mapping to 010; slightly condensed character spacing.</td>
                    <td>Book printing and news publishing where narrow margins are needed.</td>
                  </tr>
                  <tr>
                    <td class="font-bold">Kruti Dev 055</td>
                    <td>Identical mapping; features minor adjustments to spacing and punctuation.</td>
                    <td>Form printing and custom design headers.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- Internal Link / CTA to Font Page -->
          <section class="border border-slate-200/60 dark:border-slate-800/60 rounded-3xl bg-radial from-brand-50/20 via-white to-white dark:from-brand-950/10 dark:via-slate-900 dark:to-slate-900 p-6 sm:p-8 text-center">
            <h2>Need the font too? Download KrutiDev font here</h2>
            <p class="text-sm leading-relaxed mb-6">
              To view or edit documents using this layout offline, you must have the font file installed on your system. Without it, your typing will render in unreadable English characters.
            </p>
            <div class="max-w-md mx-auto">
              <a
                href="/krutidev-font-download"
                class="w-full inline-flex items-center justify-center px-5 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-brand-500 dark:hover:border-brand-500/40 text-sm font-semibold text-slate-800 dark:text-slate-200 hover:shadow-xs hover:shadow-md transition-all cursor-pointer active:scale-98"
              >
                <span>Download KrutiDev Font File (.ttf) →</span>
              </a>
            </div>
          </section>

        </div>
      </div>

      <!-- FAQ Section (Reusing FAQ component) -->
      <FAQ items={faqs} title="Frequently Asked Questions" />

      <!-- Related Tools -->
      <RelatedTools />

    </div>
  </div>
</Layout>

<style>
  .download-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .download-container h2 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #0f172a;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .dark .download-container h2 {
    color: #f8fafc;
  }
  
  .download-container h2::before {
    content: "";
    display: inline-block;
    width: 0.375rem;
    height: 1.25rem;
    border-radius: 0.125rem;
    background-color: #ea580c;
  }
  
  .download-container p {
    font-size: 0.875rem;
    line-height: 1.625;
    margin-bottom: 1rem;
  }

  /* Orange/branded download button */
  .download-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #ea580c; /* Branded Orange 600 */
    color: #ffffff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.875rem 2rem;
    border-radius: 0.75rem;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(234, 88, 12, 0.25), 0 2px 4px -2px rgba(234, 88, 12, 0.2);
    text-decoration: none;
    cursor: pointer;
    border: none;
    min-height: 44px;
  }
  
  .download-btn:hover {
    background-color: #c2410c; /* Branded Orange 700 */
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(234, 88, 12, 0.35), 0 4px 6px -4px rgba(234, 88, 12, 0.3);
  }
  
  .download-btn:active {
    transform: translateY(0);
    scale: 0.98;
  }
  
  /* Clean table styling */
  .font-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    font-size: 0.825rem;
    text-align: left;
    background-color: transparent;
  }
  
  .font-table th, .font-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  
  .dark .font-table th, .dark .font-table td {
    border-bottom: 1px solid #1e293b;
  }
  
  .font-table th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  
  .dark .font-table th {
    background-color: #0f172a;
    color: #cbd5e1;
  }
  
  .font-table tr:last-child td {
    border-bottom: none;
  }
  
  .font-table tr:hover {
    background-color: #f8fafc/50;
  }
  
  .dark .font-table tr:hover {
    background-color: #1e293b/30;
  }
</style>
