---
import Layout from './Layout.astro';
import Converter from '../components/Converter.astro';
import HowToUse from '../components/HowToUse.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';

import { CONVERTERS } from '../config/converters';

interface Props {
  converterId: string;
  schema?: Record<string, any> | Record<string, any>[];
}

const { converterId, schema } = Astro.props;

// Find the converter info
const converter = CONVERTERS.find(c => c.id === converterId);

if (!converter) {
  throw new Error(`Converter configuration for ID "${converterId}" not found in registry.`);
}

// Generate JSON-LD SoftwareApplication & WebApplication schemas
const defaultSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": converter.name,
    "description": converter.description,
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript.",
    "url": new URL(converter.href, Astro.site || 'https://fontconverterhub.com').href
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": `${converter.name} Tool`,
    "description": converter.longDescription || converter.description,
    "url": new URL(converter.href, Astro.site || 'https://fontconverterhub.com').href,
    "applicationCategory": "Utility",
    "browserRequirements": "Requires JavaScript."
  }
];
---

<Layout
  title={converter.name}
  description={converter.description}
  schema={schema || defaultSchemas}
>
  <div class="pt-6 pb-16 bg-radial from-brand-50/10 via-transparent to-transparent dark:from-brand-950/5 animate-fade-in">
    <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6 space-y-8">
      
      <!-- Converter Section (Converter first) -->
      <Converter
        direction={converter.id}
        inputPlaceholder={converter.placeholders.input}
        outputPlaceholder={converter.placeholders.output}
        swapTarget={converter.swapTarget}
        examples={converter.examples}
      />

      <!-- Compact Utility Title -->
      <div class="text-left select-none max-w-5xl pl-1">
        <h1 class="text-lg font-bold text-slate-900 dark:text-slate-100 tracking-tight leading-none">
          {converter.name}
        </h1>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1.5 leading-none">
          {converter.longDescription || converter.description}
        </p>
      </div>

      <!-- How To Use (How to use second) -->
      {converter.howTo && converter.howTo.steps && converter.howTo.steps.length > 0 && (
        <HowToUse
          title={converter.howTo.title}
          steps={converter.howTo.steps}
          type={converter.howTo.type}
        />
      )}

      <!-- About Section -->
      {converter.about && converter.about.paragraphs && converter.about.paragraphs.length > 0 && (
        <section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs animate-fade-in">
          <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
            <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {converter.about.title}
          </h2>
          <div class="text-sm text-slate-650 dark:text-slate-350 space-y-4 leading-relaxed font-normal">
            {converter.about.paragraphs.map((para) => (
              <p set:html={para} />
            ))}
          </div>
        </section>
      )}

      <!-- Related Tools (Related tools fourth) -->
      <RelatedTools currentPath={converter.href} />

      <!-- FAQ Section (FAQ at the bottom, just above footer) -->
      {converter.faq && converter.faq.length > 0 && (
        <FAQ items={converter.faq} />
      )}

    </div>
  </div>
</Layout>
