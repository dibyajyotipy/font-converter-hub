---
import { CONVERTERS } from '../config/converters';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const normalizePath = (p: string) => p.replace(/\/$/, '') || '/';
const filteredTools = CONVERTERS.filter(tool => normalizePath(tool.href) !== normalizePath(currentPath));
---

<section class="max-w-5xl mx-auto my-10 animate-fade-in">
  <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
    <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
    </svg>
    Related Converters
  </h2>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {filteredTools.map((tool) => (
      <a
        href={tool.href}
        class={`flex flex-col p-5 border rounded-2xl bg-white dark:bg-slate-900 transition-all duration-200 select-none ${
          tool.href === '#'
            ? 'opacity-50 cursor-not-allowed border-slate-200/60 dark:border-slate-800/60'
            : 'border-slate-200 dark:border-slate-800 hover:border-brand-500/50 dark:hover:border-brand-500/30 hover:shadow-xs active:scale-98 focus:outline-hidden focus:ring-2 focus:ring-brand-500/30'
        }`}
      >
        <div class="flex items-center justify-between mb-1.5">
          <h3 class="text-sm font-semibold text-slate-800 dark:text-slate-200">
            {tool.name}
          </h3>
          {tool.badge && (
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200/10">
              {tool.badge}
            </span>
          )}
        </div>
        <p class="text-xs text-slate-500 dark:text-slate-450 leading-relaxed font-normal">
          {tool.description}
        </p>
      </a>
    ))}
  </div>
</section>
