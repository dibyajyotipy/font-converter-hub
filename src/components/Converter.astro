---
import type { ExampleData } from '../config/converters';

interface Props {
  direction: string;
  inputPlaceholder: string;
  outputPlaceholder: string;
  swapTarget?: string;
  examples?: ExampleData;
  inputLabel?: string;
  outputLabel?: string;
}

const { direction, inputPlaceholder, outputPlaceholder, swapTarget, examples, inputLabel, outputLabel } = Astro.props;

// Generate unique ID suffix to avoid duplicate DOM IDs in multi-instance environments
const idSuffix = Math.random().toString(36).substring(2, 9);
const inputId = `converter-input-${idSuffix}`;
const outputId = `converter-output-${idSuffix}`;
---

<div 
  class="w-full font-converter-container" 
  data-direction={direction}
  data-swap-target={swapTarget}
  data-examples={JSON.stringify(examples)}
>
  <!-- Unified Layout Card Container (Workspace Theme, smooth focus transition) -->
  <div class="flex flex-col border border-slate-200 dark:border-slate-800 rounded-2xl bg-slate-50 dark:bg-slate-900 shadow-sm overflow-hidden transition-all duration-200 focus-within:border-brand-500 dark:focus-within:border-brand-450 focus-within:ring-2 focus-within:ring-brand-500/10">
    
    <!-- Language/Direction Switcher Header (Google Translate-like) -->
    <div class="flex items-center justify-between px-4 py-2 bg-transparent select-none">
      <div class="flex-1 text-left">
        <span class="text-xs font-semibold text-slate-655 dark:text-slate-350">
          {inputLabel || (direction === 'krutidev-to-mangal' || direction === 'krutidev-to-unicode' ? 'Krutidev 010' : 'Unicode Devanagari')}
        </span>
      </div>
      
      <!-- Swap Button (Touch-optimized to >= 44x44px target via pseudo-element) -->
      <button
        type="button"
        class="btn-swap group w-9 h-9 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-xs hover:shadow-sm text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 transition-all duration-300 cursor-pointer focus:outline-hidden focus:ring-2 focus:ring-brand-500/50 flex items-center justify-center active:scale-95 relative after:absolute after:-inset-1.5 after:rounded-full after:content-['']"
        title="Swap conversion direction"
        aria-label="Swap conversion direction"
      >
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
        </svg>
      </button>
      
      <div class="flex-1 text-right">
        <span class="text-xs font-semibold text-slate-655 dark:text-slate-350">
          {outputLabel || (direction === 'krutidev-to-mangal' || direction === 'krutidev-to-unicode' ? 'Unicode Devanagari' : 'Krutidev 010')}
        </span>
      </div>
    </div>

    <!-- Textareas Split-Grid (Divided on desktop, stacked on mobile) -->
    <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-slate-200 dark:divide-slate-800 bg-transparent border-y border-slate-200/80 dark:border-slate-800/80">
      
      <!-- Input Panel -->
      <div class="flex flex-col bg-transparent relative">
        <!-- Example Chips Bar (Helper links, low visual weight) -->
        {examples && examples.chips && examples.chips.length > 0 && (
          <div class="examples-bar px-4 py-2 flex flex-wrap items-center gap-1.5 select-none bg-transparent">
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500">Try:</span>
            {examples.chips.map((chip, index) => (
              <button
                type="button"
                data-chip-index={index}
                class="btn-example-chip px-2 py-0.5 text-[10px] font-medium text-slate-600 dark:text-slate-350 hover:text-brand-650 dark:hover:text-brand-400 bg-slate-200/60 hover:bg-slate-200 dark:bg-slate-800/40 dark:hover:bg-slate-800/85 rounded-md transition-colors cursor-pointer border border-transparent"
              >
                {chip.label.replace('Sample ', '').replace('Government ', '').replace('Hindi ', '')}
              </button>
            ))}
          </div>
        )}

        <label for={inputId} class="sr-only">Input text in {inputLabel || (direction === 'krutidev-to-mangal' || direction === 'krutidev-to-unicode' ? 'Krutidev 010' : 'Unicode Devanagari')}</label>
        <textarea
          id={inputId}
          placeholder={inputPlaceholder}
          class="converter-input w-full h-[210px] md:h-[260px] pt-3 px-4 pb-3 text-slate-800 dark:text-slate-200 bg-transparent border-0 focus:outline-hidden focus:ring-0 resize-none font-sans text-base leading-relaxed"
        ></textarea>
        
        <!-- Input Stats Bar -->
        <div class="px-4 py-2 border-t border-slate-200/80 dark:border-slate-800/80 flex gap-3 font-mono font-bold select-none text-[10px] text-slate-400/80 dark:text-slate-500/80">
          <span>CHARS: <span class="input-char-count text-slate-500 dark:text-slate-400">0</span></span>
          <span>WORDS: <span class="input-word-count text-slate-500 dark:text-slate-400">0</span></span>
        </div>
      </div>

      <!-- Output Panel -->
      <div class="flex flex-col bg-transparent relative">
        <!-- Symmetrical Header Bar for Output -->
        <div class="px-4 py-2 flex items-center justify-between select-none bg-transparent">
          <span class="text-[10px] font-semibold text-slate-450 dark:text-slate-550">Result Preview</span>
          <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-emerald-600/80 dark:text-emerald-500/80">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Instant
          </span>
        </div>

        <label for={outputId} class="sr-only">Converted text in {outputLabel || (direction === 'krutidev-to-mangal' || direction === 'krutidev-to-unicode' ? 'Unicode Devanagari' : 'Krutidev 010')}</label>
        <textarea
          id={outputId}
          readonly
          placeholder={outputPlaceholder}
          class="converter-output w-full h-[210px] md:h-[260px] pt-3 px-4 pb-3 text-slate-800 dark:text-slate-200 bg-transparent border-0 focus:outline-hidden focus:ring-0 resize-none font-sans text-base leading-relaxed cursor-not-allowed"
        ></textarea>
        
        <!-- Output Stats Bar -->
        <div class="px-4 py-2 border-t border-slate-200/80 dark:border-slate-800/80 flex gap-3 font-mono font-bold select-none text-[10px] text-slate-400/80 dark:text-slate-500/80">
          <span>CHARS: <span class="output-char-count text-slate-500 dark:text-slate-400">0</span></span>
          <span>WORDS: <span class="output-word-count text-slate-500 dark:text-slate-400">0</span></span>
        </div>
      </div>

    </div>

    <!-- Unified Utility Toolbar -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-4 py-2.5 bg-transparent">
      <!-- Left actions (Tertiary) -->
      <div class="flex items-center gap-2 w-full sm:w-auto">
        <button
          type="button"
          class="btn-example flex-1 sm:flex-none px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 hover:bg-slate-100/60 dark:hover:bg-slate-800/50 rounded-xl transition-all cursor-pointer min-h-[44px] flex items-center justify-center focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98"
        >
          Try Example
        </button>
        <button
          type="button"
          disabled
          class="btn-clear flex-1 sm:flex-none px-4 py-2 text-xs font-semibold text-slate-500 hover:text-slate-850 dark:text-slate-400 dark:hover:text-slate-200 hover:bg-slate-100/60 dark:hover:bg-slate-800/50 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 min-h-[44px] focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 opacity-50 cursor-not-allowed pointer-events-none"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Clear
        </button>
      </div>
      
      <!-- Right actions (Secondary & Primary) -->
      <div class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
        <button
          type="button"
          disabled
          class="btn-download flex-1 sm:flex-none px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-250 hover:text-slate-900 dark:hover:text-white bg-white hover:bg-slate-50 dark:bg-slate-850 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-805/80 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 min-h-[44px] focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 opacity-50 cursor-not-allowed pointer-events-none shadow-2xs"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download TXT
        </button>
        <button
          type="button"
          disabled
          class="btn-docx flex-1 sm:flex-none px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-250 hover:text-slate-900 dark:hover:text-white bg-white hover:bg-slate-50 dark:bg-slate-850 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-805/80 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 min-h-[44px] focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 opacity-50 cursor-not-allowed pointer-events-none shadow-2xs"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Word
        </button>
        <button
          type="button"
          disabled
          class="btn-whatsapp flex-1 sm:flex-none px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-250 hover:text-slate-900 dark:hover:text-white bg-white hover:bg-slate-50 dark:bg-slate-850 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-805/80 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 min-h-[44px] focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 opacity-50 cursor-not-allowed pointer-events-none shadow-2xs"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          WhatsApp
        </button>
        <button
          type="button"
          disabled
          class="btn-email flex-1 sm:flex-none px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-250 hover:text-slate-900 dark:hover:text-white bg-white hover:bg-slate-50 dark:bg-slate-850 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-805/80 rounded-xl transition-all cursor-pointer flex items-center justify-center gap-1.5 min-h-[44px] focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 opacity-50 cursor-not-allowed pointer-events-none shadow-2xs"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email
        </button>
        <button
          type="button"
          disabled
          class="btn-copy flex-1 sm:flex-none px-5 py-2 text-xs font-bold text-white bg-brand-600 hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600 rounded-xl shadow-xs transition-all cursor-pointer flex items-center justify-center gap-1.5 min-h-[44px] focus:outline-hidden focus:ring-2 focus:ring-brand-500 active:scale-98 opacity-50 cursor-not-allowed pointer-events-none"
        >
          <!-- Copy Icon -->
          <svg class="copy-icon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
          <!-- Check Icon -->
          <svg class="check-icon w-3.5 h-3.5 hidden text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="copy-text">Copy Result</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Integrated Trust Messaging -->
  <div class="mt-3.5 text-center text-xs tracking-wide font-medium text-slate-400 dark:text-slate-500 select-none">
    <span>Private &bull; Browser-Based &bull; No Upload Required</span>
  </div>
</div>

<script>
  import { CONVERSION_FUNCTIONS } from '../utils/conversionRegistry';
  import { Document, Packer, Paragraph, TextRun } from 'docx';

  const initConverters = () => {
    const containers = document.querySelectorAll('.font-converter-container');
    
    containers.forEach((container) => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const direction = container.getAttribute('data-direction');
      const swapTarget = container.getAttribute('data-swap-target');
      const examplesData = container.getAttribute('data-examples');
      
      let examples: any = null;
      if (examplesData) {
        try {
          examples = JSON.parse(examplesData);
        } catch (e) {
          console.error('Failed to parse examples data:', e);
        }
      }

      const textareaInput = container.querySelector('.converter-input') as HTMLTextAreaElement;
      const textareaOutput = container.querySelector('.converter-output') as HTMLTextAreaElement;
      
      const inputCharVal = container.querySelector('.input-char-count') as HTMLSpanElement;
      const inputWordVal = container.querySelector('.input-word-count') as HTMLSpanElement;
      const outputCharVal = container.querySelector('.output-char-count') as HTMLSpanElement;
      const outputWordVal = container.querySelector('.output-word-count') as HTMLSpanElement;

      const btnClear = container.querySelector('.btn-clear') as HTMLButtonElement;
      const btnCopy = container.querySelector('.btn-copy') as HTMLButtonElement;
      const btnDownload = container.querySelector('.btn-download') as HTMLButtonElement;
      const btnDocx = container.querySelector('.btn-docx') as HTMLButtonElement;
      const btnWhatsapp = container.querySelector('.btn-whatsapp') as HTMLButtonElement;
      const btnEmail = container.querySelector('.btn-email') as HTMLButtonElement;
      const btnSwap = container.querySelector('.btn-swap') as HTMLButtonElement;
      const btnExample = container.querySelector('.btn-example') as HTMLButtonElement;

      const copyTextEl = container.querySelector('.copy-text') as HTMLSpanElement;
      const copyIconEl = container.querySelector('.copy-icon') as SVGElement;
      const checkIconEl = container.querySelector('.check-icon') as SVGElement;

      if (!textareaInput || !textareaOutput) return;

      const countStats = (text: string) => {
        const charCount = text.length;
        const cleanText = text.trim();
        const wordCount = cleanText === '' ? 0 : cleanText.split(/\s+/).length;
        return { charCount, wordCount };
      };

      const setButtonDisabledState = (btn: HTMLButtonElement, disable: boolean, addPointerEvents: boolean = true) => {
        if (!btn) return;
        if (disable) {
          btn.setAttribute('disabled', 'true');
          btn.classList.add('opacity-50', 'cursor-not-allowed');
          if (addPointerEvents) {
            btn.classList.add('pointer-events-none');
          } else {
            btn.classList.remove('pointer-events-none');
          }
        } else {
          btn.removeAttribute('disabled');
          btn.classList.remove('opacity-50', 'cursor-not-allowed', 'pointer-events-none');
        }
      };

      const updateButtonStates = () => {
        const hasInput = textareaInput.value.length > 0;
        const outVal = textareaOutput.value;
        const hasOutput = outVal.length > 0;
        const outLength = outVal.length;

        setButtonDisabledState(btnClear, !hasInput);
        setButtonDisabledState(btnCopy, !hasOutput);
        setButtonDisabledState(btnDownload, !hasOutput);
        setButtonDisabledState(btnDocx, !hasOutput);

        if (btnWhatsapp) {
          if (!hasOutput) {
            setButtonDisabledState(btnWhatsapp, true, true);
            btnWhatsapp.removeAttribute('title');
          } else if (outLength > 1500) {
            setButtonDisabledState(btnWhatsapp, true, false);
            btnWhatsapp.setAttribute('title', 'Text too long for WhatsApp sharing — use Download instead');
          } else {
            setButtonDisabledState(btnWhatsapp, false);
            btnWhatsapp.removeAttribute('title');
          }
        }

        if (btnEmail) {
          if (!hasOutput) {
            setButtonDisabledState(btnEmail, true, true);
            btnEmail.removeAttribute('title');
          } else if (outLength > 1500) {
            setButtonDisabledState(btnEmail, true, false);
            btnEmail.setAttribute('title', 'Text too long for email sharing — use Download instead');
          } else {
            setButtonDisabledState(btnEmail, false);
            btnEmail.removeAttribute('title');
          }
        }
      };

      const updateCounts = () => {
        const inVal = textareaInput.value;
        const outVal = textareaOutput.value;

        const inStats = countStats(inVal);
        const outStats = countStats(outVal);

        if (inputCharVal) inputCharVal.textContent = inStats.charCount.toString();
        if (inputWordVal) inputWordVal.textContent = inStats.wordCount.toString();
        if (outputCharVal) outputCharVal.textContent = outStats.charCount.toString();
        if (outputWordVal) outputWordVal.textContent = outStats.wordCount.toString();

        updateButtonStates();
      };

      const handleConversion = () => {
        const text = textareaInput.value;
        let convertedText = '';

        if (text && direction) {
          try {
            const convertFn = CONVERSION_FUNCTIONS[direction];
            if (convertFn) {
              convertedText = convertFn(text);
            } else {
              console.warn(`No conversion function found for direction: ${direction}`);
              convertedText = text;
            }
          } catch (err) {
            console.error('Conversion failed: ', err);
            convertedText = 'Error: Conversion failed. Please verify your input.';
          }
        }

        textareaOutput.value = convertedText;
        updateCounts();

        // Automatically scroll preview box to the bottom to keep the latest text in view
        textareaOutput.scrollTop = textareaOutput.scrollHeight;
      };

      // Keystroke Conversion
      textareaInput.addEventListener('input', handleConversion);

      // Synchronize scroll positions between input and output textareas
      textareaInput.addEventListener('scroll', () => {
        const maxScrollInput = textareaInput.scrollHeight - textareaInput.clientHeight;
        if (maxScrollInput > 0) {
          const scrollPct = textareaInput.scrollTop / maxScrollInput;
          const maxScrollOutput = textareaOutput.scrollHeight - textareaOutput.clientHeight;
          textareaOutput.scrollTop = scrollPct * maxScrollOutput;
        }
      });

      // Clear Screen
      if (btnClear) {
        btnClear.addEventListener('click', () => {
          textareaInput.value = '';
          textareaOutput.value = '';
          updateCounts();
          textareaInput.focus();
        });
      }

      // Populate Example Data
      if (btnExample && examples && examples.default) {
        btnExample.addEventListener('click', () => {
          textareaInput.value = examples.default;
          handleConversion();
          textareaInput.focus();
        });
      }

      // Populate Example Chips dynamically
      const btnChips = container.querySelectorAll('.btn-example-chip');
      btnChips.forEach((btn) => {
        btn.addEventListener('click', () => {
          const indexAttr = btn.getAttribute('data-chip-index');
          if (indexAttr !== null && examples && examples.chips) {
            const index = parseInt(indexAttr, 10);
            const chip = examples.chips[index];
            if (chip) {
              textareaInput.value = chip.text;
              handleConversion();
              textareaInput.focus();
            }
          }
        });
      });

      // Download text as a local .txt file (100% offline client-side download)
      if (btnDownload) {
        btnDownload.addEventListener('click', () => {
          const textToDownload = textareaOutput.value;
          if (!textToDownload) return;

          const blob = new Blob([textToDownload], { type: 'text/plain;charset=utf-8' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `font-converter-output-${direction}.txt`;
          a.click();
          URL.revokeObjectURL(url);
        });
      }

      // Download Word document (.docx)
      if (btnDocx) {
        btnDocx.addEventListener('click', () => {
          const textToDownload = textareaOutput.value;
          if (!textToDownload) return;

          const lines = textToDownload.split('\n');
          const children = lines.map((line, index) => {
            return new TextRun({
              text: line,
              break: index > 0 ? 1 : undefined
            });
          });

          const doc = new Document({
            sections: [
              {
                properties: {},
                children: [
                  new Paragraph({
                    children: children
                  })
                ]
              }
            ]
          });

          Packer.toBlob(doc).then((blob) => {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `converted-text.docx`;
            a.click();
            URL.revokeObjectURL(url);
          }).catch((err) => {
            console.error('Failed to generate docx:', err);
            alert('Failed to generate Word document.');
          });
        });
      }

      // Share via WhatsApp
      if (btnWhatsapp) {
        btnWhatsapp.addEventListener('click', () => {
          const textToShare = textareaOutput.value;
          if (!textToShare || textToShare.length > 1500) return;

          const url = `https://wa.me/?text=${encodeURIComponent(textToShare)}`;
          window.open(url, '_blank');
        });
      }

      // Share via Email
      if (btnEmail) {
        btnEmail.addEventListener('click', () => {
          const textToShare = textareaOutput.value;
          if (!textToShare || textToShare.length > 1500) return;

          const url = `mailto:?subject=Converted Text&body=${encodeURIComponent(textToShare)}`;
          window.location.href = url;
        });
      }

      // Swap Languages (Redirects opposite page while carrying content inside URL search parameter)
      if (btnSwap) {
        if (swapTarget) {
          btnSwap.addEventListener('click', () => {
            const currentOutput = textareaOutput.value;
            if (currentOutput) {
              window.location.href = `${swapTarget}?text=${encodeURIComponent(currentOutput)}`;
            } else {
              window.location.href = swapTarget;
            }
          });
        } else {
          // Hide swap button if no target exists
          btnSwap.style.display = 'none';
        }
      }

      const showCopySuccess = () => {
        if (copyTextEl) copyTextEl.textContent = 'Copied ✓';
        if (copyIconEl) copyIconEl.classList.add('hidden');
        if (checkIconEl) checkIconEl.classList.remove('hidden');
        btnCopy.classList.remove('bg-brand-600', 'hover:bg-brand-700', 'dark:bg-brand-500', 'dark:hover:bg-brand-600');
        btnCopy.classList.add('bg-emerald-600', 'hover:bg-emerald-700', 'dark:bg-emerald-500', 'dark:hover:bg-emerald-650');

        setTimeout(() => {
          if (copyTextEl) copyTextEl.textContent = 'Copy Result';
          if (copyIconEl) copyIconEl.classList.remove('hidden');
          if (checkIconEl) checkIconEl.classList.add('hidden');
          btnCopy.classList.remove('bg-emerald-600', 'hover:bg-emerald-700', 'dark:bg-emerald-500', 'dark:hover:bg-emerald-650');
          btnCopy.classList.add('bg-brand-600', 'hover:bg-brand-700', 'dark:bg-brand-500', 'dark:hover:bg-brand-600');
        }, 2000);
      };

      const selectOutputForManualCopy = () => {
        textareaOutput.focus();
        textareaOutput.select();
        textareaOutput.setSelectionRange(0, textareaOutput.value.length);
      };

      // Copy Content with Fallback
      if (btnCopy) {
        btnCopy.addEventListener('click', async () => {
          const textToCopy = textareaOutput.value;
          if (!textToCopy) return;

          try {
            await navigator.clipboard.writeText(textToCopy);
            showCopySuccess();
          } catch (err) {
            console.warn('Clipboard API failed, selecting text for manual copy: ', err);
            try {
              selectOutputForManualCopy();
              alert('Copy failed. The text has been selected so you can copy it manually.');
            } catch (fallbackErr) {
              console.error('Manual copy fallback failed: ', fallbackErr);
              alert('Failed to copy text. Please select the text and copy manually.');
            }
          }
        });
      }

      // On-load query text translation check
      const params = new URLSearchParams(window.location.search);
      const initialText = params.get('text');
      if (initialText) {
        textareaInput.value = initialText;
        handleConversion();
        // Clean address bar parameter without reloading for canonical SEO status
        const cleanUrl = window.location.pathname;
        window.history.replaceState({}, document.title, cleanUrl);
      }

      // Run initial setup for disabled button states
      updateButtonStates();
    });
  };

  initConverters();
  document.addEventListener('astro:after-swap', () => {
    document.querySelectorAll('.font-converter-container').forEach((el) => {
      el.removeAttribute('data-initialized');
    });
    initConverters();
  });
</script>
