---
interface Props {
  title: string;
  steps: string[];
  type?: 'brand' | 'amber';
}

const { title, steps } = Astro.props;
---

<section class="max-w-5xl mx-auto my-10 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-2xs">
  <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 flex items-center gap-2 select-none tracking-tight">
    <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    {title}
  </h2>
  <ol class="list-decimal pl-5 text-sm text-slate-650 dark:text-slate-350 space-y-2.5 leading-relaxed font-normal">
    {steps.map((step) => (
      <li set:html={step} class="pl-1.5" />
    ))}
  </ol>
</section>
