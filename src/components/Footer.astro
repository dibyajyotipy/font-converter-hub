---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 dark:border-slate-800/60 bg-white dark:bg-slate-950 text-slate-500 dark:text-slate-400 py-12 transition-colors duration-200">
  <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <!-- About -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-4 group min-h-[44px] w-fit" aria-label="Font Converter Hub Home">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-tr from-brand-600 to-indigo-500 text-white font-bold text-base shadow-sm group-hover:scale-105 transition-transform">
            अ
          </span>
          <span class="font-bold text-slate-800 dark:text-slate-200 tracking-tight group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
            Font Converter Hub
          </span>
        </a>
        <p class="text-xs sm:text-sm leading-relaxed max-w-sm">
          A modern, secure, and fast developer utility for Hindi and Sanskrit font conversion. Convert Krutidev (classic typewriter font) to Unicode, and Unicode back to Krutidev seamlessly.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-slate-900 dark:text-slate-100 text-sm tracking-wider uppercase mb-4">
          Conversion Utilities
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/krutidev-to-unicode" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors min-h-[40px] inline-flex items-center">
              Krutidev to Unicode
            </a>
          </li>
          <li>
            <a href="/unicode-to-krutidev" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors min-h-[40px] inline-flex items-center">
              Unicode to Krutidev
            </a>
          </li>
        </ul>
      </div>

      <!-- Information & Legal -->
      <div>
        <h3 class="font-semibold text-slate-900 dark:text-slate-100 text-sm tracking-wider uppercase mb-4">
          Information & Legal
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/about" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors min-h-[40px] inline-flex items-center">
              About Us
            </a>
          </li>
          <li>
            <a href="/contact" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors min-h-[40px] inline-flex items-center">
              Contact Support
            </a>
          </li>
          <li>
            <a href="/terms" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors min-h-[40px] inline-flex items-center">
              Terms of Use
            </a>
          </li>
          <li>
            <a href="/privacy" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors min-h-[40px] inline-flex items-center">
              Privacy Policy
            </a>
          </li>
        </ul>
      </div>

      <!-- Features / Privacy -->
      <div>
        <h3 class="font-semibold text-slate-900 dark:text-slate-100 text-sm tracking-wider uppercase mb-4">
          Core Features
        </h3>
        <ul class="space-y-2.5 text-xs sm:text-sm">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            100% Client-side conversion
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Works Offline & Fast loading
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            One-click Copy & Clear actions
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-slate-100 dark:border-slate-800/40 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>
        &copy; {currentYear} Font Converter Hub. All rights reserved.
      </p>
      <div class="flex gap-4">
        <span class="text-slate-400 dark:text-slate-600 font-medium">Built with Astro & Tailwind CSS v4</span>
      </div>
    </div>
  </div>
</footer>
