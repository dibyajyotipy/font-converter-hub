---
interface Props {
  title?: string;
  items: { q: string; a: string }[];
}

const { title = "Frequently Asked Questions", items } = Astro.props;
---

<section class="max-w-5xl mx-auto my-10 animate-fade-in">
  <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 mb-3.5 tracking-tight flex items-center gap-2 select-none">
    <svg class="w-4.5 h-4.5 text-brand-500 dark:text-brand-450" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    {title}
  </h2>
  
  <div class="border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 rounded-2xl overflow-hidden divide-y divide-slate-150 dark:divide-slate-800/60 transition-all duration-200 shadow-2xs">
    {items.map((faq) => (
      <details class="group cursor-pointer focus-within:outline-hidden">
        <summary class="font-semibold text-sm text-slate-850 dark:text-slate-200 px-5 py-4 flex justify-between items-center outline-hidden hover:bg-slate-50/40 dark:hover:bg-slate-950/20 transition-colors">
          {faq.q}
          <span class="text-slate-400 group-hover:text-brand-500 group-open:rotate-180 transition-transform duration-200 text-[10px]" aria-hidden="true">&#9660;</span>
        </summary>
        <div class="px-5 pb-5 pt-1 text-sm text-slate-600 dark:text-slate-400 leading-relaxed border-t border-transparent bg-slate-50/10 dark:bg-slate-950/5">
          <p>{faq.a}</p>
        </div>
      </details>
    ))}
  </div>
</section>
