---
interface Props {
  items: { name: string; href?: string }[];
}

const { items } = Astro.props;

// Generate JSON-LD BreadcrumbList Schema dynamically
const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": new URL(item.href || Astro.url.pathname, Astro.site || 'https://fontconverterhub.com').href
  }))
};
---

<nav aria-label="Breadcrumb" class="w-full max-w-5xl mx-auto my-4 px-2 select-none">
  <ol class="flex flex-wrap items-center gap-2 text-xs font-semibold text-slate-500 dark:text-slate-400">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && (
          <span class="text-slate-400 dark:text-slate-600 select-none" aria-hidden="true">&gt;</span>
        )}
        {item.href ? (
          <a
            href={item.href}
            class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors focus:outline-hidden"
          >
            {item.name}
          </a>
        ) : (
          <span class="text-slate-800 dark:text-slate-200" aria-current="page">
            {item.name}
          </span>
        )}
      </li>
    ))}
  </ol>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
</nav>
