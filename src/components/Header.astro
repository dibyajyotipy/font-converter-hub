---
import ThemeToggle from './ThemeToggle.astro';
import { NAV_ITEMS, type NavLink, type NavDropdown } from '../config/nav';

const currentPath = Astro.url.pathname;
const flatNavItems = NAV_ITEMS.filter(item => !('links' in item)) as NavLink[];
const dropdownNavItems = NAV_ITEMS.filter(item => 'links' in item) as NavDropdown[];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200/50 dark:border-slate-800/50 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md transition-colors duration-200">
  <div class="max-w-[1600px] w-[96%] mx-auto px-2 sm:px-4 lg:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo/Brand -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2 group min-h-[44px]">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-tr from-brand-600 to-indigo-500 text-white font-bold text-lg shadow-md group-hover:scale-105 transition-transform">
            अ
          </span>
          <span class="font-extrabold text-lg sm:text-xl tracking-tight bg-gradient-to-r from-slate-900 to-slate-700 dark:from-white dark:to-slate-300 bg-clip-text text-transparent group-hover:from-brand-600 dark:group-hover:to-brand-400 transition-colors">
            Font Converter Hub
          </span>
        </a>
      </div>

      <!-- Desktop Navigation (Flat links only) -->
      <nav class="hidden md:flex items-center gap-6">
        {flatNavItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class={`text-sm font-semibold transition-colors duration-200 hover:text-brand-600 dark:hover:text-brand-400 min-h-[44px] flex items-center ${
                isActive
                  ? 'text-brand-600 dark:text-brand-400'
                  : 'text-slate-650 dark:text-slate-350'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Right actions (Dropdowns + Dark Mode toggle + Hamburger) -->
      <div class="flex items-center gap-3">
        <!-- Desktop Dropdowns positioned near the dark mode toggle -->
        <div class="hidden md:flex items-center gap-4">
          {dropdownNavItems.map((item) => (
            <div class="relative dropdown-container">
              <button
                class="flex items-center gap-1 text-sm font-semibold text-slate-655 hover:text-brand-600 dark:text-slate-305 dark:hover:text-brand-400 min-h-[44px] cursor-pointer transition-colors focus:outline-hidden"
                aria-haspopup="true"
                aria-expanded="false"
                data-dropdown-trigger
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              
              <div
                class="absolute right-0 mt-1 w-56 rounded-xl border border-slate-200/60 dark:border-slate-800 bg-white dark:bg-slate-900 p-2 shadow-lg opacity-0 invisible translate-y-2 scale-98 transition-all duration-200 z-50 dropdown-panel before:content-[''] before:absolute before:-top-2 before:left-0 before:right-0 before:h-2"
                role="menu"
              >
                {item.links.map((link) => {
                  if ('divider' in link) {
                    return <div class="border-t border-slate-200 dark:border-slate-700/80 my-1.5 mx-2" role="separator" />;
                  }
                  if ('header' in link) {
                    return (
                      <div class="text-[10px] font-medium tracking-[0.07em] uppercase text-slate-400 dark:text-slate-505 mt-[6px] mx-[12px] mb-[2px]">
                        {link.header}
                      </div>
                    );
                  }
                  const isActive = currentPath === link.href;
                  return (
                    <a
                      href={link.href}
                      role="menuitem"
                      class={`block px-3 py-2 text-xs font-semibold rounded-lg transition-colors ${
                        isActive
                          ? 'text-brand-600 dark:text-brand-400 bg-brand-50/20 dark:bg-brand-950/10 hover:bg-brand-50/30 dark:hover:bg-brand-950/20 hover:text-brand-600 dark:hover:text-brand-400'
                          : link.isAccent
                            ? 'text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 hover:bg-brand-50/20 dark:hover:bg-brand-950/15'
                            : 'text-slate-655 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-850 hover:text-brand-600 dark:hover:text-brand-400'
                      }`}
                    >
                      {link.label}
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>

        <ThemeToggle />
        
        <!-- Mobile Menu Toggle Button (Touch-optimized to >= 44x44px) -->
        <button
          id="mobile-menu-toggle"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          class="md:hidden min-w-[44px] min-h-[44px] flex items-center justify-center p-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:bg-slate-100 dark:hover:bg-slate-800 cursor-pointer shadow-xs focus:outline-hidden focus:ring-2 focus:ring-brand-500 transition-all duration-200"
        >
          <svg
            id="menu-icon-open"
            class="w-5 h-5 text-slate-700 dark:text-slate-355 block"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg
            id="menu-icon-close"
            class="w-5 h-5 text-slate-700 dark:text-slate-355 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Drawer Menu -->
  <div
    id="mobile-drawer"
    class="hidden md:hidden absolute left-0 right-0 border-b border-slate-200/50 dark:border-slate-800/50 bg-white dark:bg-slate-950 px-4 pt-2 pb-6 shadow-xl transition-all duration-300 ease-in-out transform -translate-y-2 opacity-0"
  >
    <nav class="flex flex-col gap-2">
      {NAV_ITEMS.map((item) => {
        if ('links' in item) {
          const dropdown = item as NavDropdown;
          return (
            <div class="w-full">
              <button
                class="w-full flex items-center justify-between px-4 py-3 min-h-[44px] rounded-xl text-sm font-semibold text-slate-655 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-900 transition-all cursor-pointer outline-hidden"
                data-mobile-dropdown-trigger
                aria-expanded="false"
              >
                {dropdown.label}
                <svg class="w-4 h-4 transition-transform duration-250" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="hidden flex-col pl-4 mt-1 mb-2 border-l border-slate-200 dark:border-slate-800 gap-1.5 overflow-hidden transition-all duration-300" data-mobile-dropdown-panel>
                {dropdown.links.map((link) => {
                  if ('divider' in link) {
                    return <div class="border-t border-slate-200 dark:border-slate-700/80 my-1.5 mx-4" role="separator" />;
                  }
                  if ('header' in link) {
                    return (
                      <div class="text-[10px] font-medium tracking-[0.07em] uppercase text-slate-400 dark:text-slate-500 px-4 py-1.5 mt-[6px] mb-[2px]">
                        {link.header}
                      </div>
                    );
                  }
                  const isActive = currentPath === link.href;
                  return (
                    <a
                      href={link.href}
                      class={`px-4 py-2.5 min-h-[40px] flex items-center rounded-lg text-xs font-semibold transition-all ${
                        isActive
                          ? 'text-brand-600 dark:text-brand-400 bg-brand-50/30 dark:bg-brand-950/15 hover:bg-brand-50/40 dark:hover:bg-brand-950/25 hover:text-brand-600 dark:hover:text-brand-400'
                          : link.isAccent
                            ? 'text-brand-600 dark:text-brand-400 bg-brand-50/10 dark:bg-brand-950/5 hover:bg-brand-50/20 dark:hover:bg-brand-950/15 hover:text-brand-700 dark:hover:text-brand-300'
                            : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900 hover:text-brand-600 dark:hover:text-brand-400'
                      }`}
                    >
                      {link.label}
                    </a>
                  );
                })}
              </div>
            </div>
          );
        } else {
          const link = item as NavLink;
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={`px-4 py-3 min-h-[44px] flex items-center rounded-xl text-sm font-semibold transition-all hover:bg-slate-50 dark:hover:bg-slate-900 ${
                isActive
                  ? 'text-brand-600 dark:text-brand-400 bg-brand-50/50 dark:bg-brand-950/20'
                  : 'text-slate-655 dark:text-slate-350'
              }`}
            >
              {link.label}
            </a>
          );
        }
      })}
    </nav>
  </div>
</header>

<style>
  /* Dropdown positioning */
  .dropdown-container {
    position: relative;
  }

  /* JavaScript-driven show fallback class */
  .dropdown-panel.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }
  
  button[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
</style>

<script>
  const setupMobileMenu = () => {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const drawer = document.getElementById('mobile-drawer');
    const openIcon = document.getElementById('menu-icon-open');
    const closeIcon = document.getElementById('menu-icon-close');

    if (!toggleBtn || !drawer || !openIcon || !closeIcon) return;

    let isExpanded = false;

    const toggleMenu = () => {
      isExpanded = !isExpanded;
      toggleBtn.setAttribute('aria-expanded', isExpanded.toString());

      if (isExpanded) {
        drawer.classList.remove('hidden');
        void drawer.offsetHeight;
        drawer.classList.remove('-translate-y-2', 'opacity-0');
        drawer.classList.add('translate-y-0', 'opacity-100');
        
        openIcon.classList.add('hidden');
        openIcon.classList.remove('block');
        closeIcon.classList.add('block');
        closeIcon.classList.remove('hidden');
      } else {
        drawer.classList.remove('translate-y-0', 'opacity-100');
        drawer.classList.add('-translate-y-2', 'opacity-0');
        
        openIcon.classList.add('block');
        openIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        closeIcon.classList.remove('block');

        const handleTransitionEnd = () => {
          if (!isExpanded) {
            drawer.classList.add('hidden');
          }
          drawer.removeEventListener('transitionend', handleTransitionEnd);
        };
        drawer.addEventListener('transitionend', handleTransitionEnd);
      }
    };

    toggleBtn.addEventListener('click', toggleMenu);

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      if (isExpanded && !toggleBtn.contains(target) && !drawer.contains(target)) {
        toggleMenu();
      }
    });
  };

  const setupDropdowns = () => {
    const containers = document.querySelectorAll('.dropdown-container');

    containers.forEach((container) => {
      const trigger = container.querySelector('[data-dropdown-trigger]');
      const panel = container.querySelector('.dropdown-panel');

      if (!trigger || !panel) return;

      let closeTimeout: any = null;

      const toggleDropdown = (show: boolean) => {
        if (show) {
          panel.classList.add('show');
          trigger.setAttribute('aria-expanded', 'true');
        } else {
          panel.classList.remove('show');
          trigger.setAttribute('aria-expanded', 'false');
        }
      };

      // Desktop Hover behavior with timeout delay
      const handleMouseEnter = () => {
        if (window.innerWidth >= 768) {
          if (closeTimeout) {
            clearTimeout(closeTimeout);
            closeTimeout = null;
          }
          toggleDropdown(true);
        }
      };

      const handleMouseLeave = () => {
        if (window.innerWidth >= 768) {
          closeTimeout = setTimeout(() => {
            toggleDropdown(false);
          }, 180); // 180ms delay
        }
      };

      // Register hover events on the parent wrapper to include the pseudo-element gap bridge
      container.addEventListener('mouseenter', handleMouseEnter);
      container.addEventListener('mouseleave', handleMouseLeave);

      // Disable clicking for desktop to trigger expand/collapse (hover-only)
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
      });

      // Keyboard support for accessibility
      trigger.addEventListener('focus', () => {
        if (window.innerWidth >= 768) {
          if (closeTimeout) {
            clearTimeout(closeTimeout);
            closeTimeout = null;
          }
          toggleDropdown(true);
        }
      });

      trigger.addEventListener('blur', () => {
        if (window.innerWidth >= 768) {
          closeTimeout = setTimeout(() => {
            toggleDropdown(false);
          }, 180);
        }
      });

      // Close when pressing Escape key
      container.addEventListener('keydown', (e: any) => {
        if (e.key === 'Escape') {
          toggleDropdown(false);
          (trigger as HTMLButtonElement).focus();
        }
      });

      // Close instantly when any link in the panel is clicked
      const links = panel.querySelectorAll('a');
      links.forEach((link) => {
        link.addEventListener('click', () => {
          toggleDropdown(false);
        });
      });
    });

    // Close when clicking outside of the dropdown container
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      document.querySelectorAll('.dropdown-panel.show').forEach((p) => {
        const container = p.closest('.dropdown-container');
        if (container && !container.contains(target)) {
          p.classList.remove('show');
          p.previousElementSibling?.setAttribute('aria-expanded', 'false');
        }
      });
    });
  };

  const setupMobileDropdowns = () => {
    const mobileTriggers = document.querySelectorAll('[data-mobile-dropdown-trigger]');
    
    mobileTriggers.forEach((trigger) => {
      const panel = trigger.nextElementSibling as HTMLElement;
      if (!panel) return;

      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', (!isExpanded).toString());
        
        if (!isExpanded) {
          panel.classList.remove('hidden');
          panel.classList.add('flex');
          const chevron = trigger.querySelector('svg');
          if (chevron) chevron.classList.add('rotate-180');
        } else {
          panel.classList.add('hidden');
          panel.classList.remove('flex');
          const chevron = trigger.querySelector('svg');
          if (chevron) chevron.classList.remove('rotate-180');
        }
      });
    });
  };

  // Run on initial load
  setupMobileMenu();
  setupDropdowns();
  setupMobileDropdowns();

  // Run on Astro View Transitions swap
  document.addEventListener('astro:after-swap', () => {
    setupMobileMenu();
    setupDropdowns();
    setupMobileDropdowns();
  });
</script>
